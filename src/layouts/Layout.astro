---
import { ClientRouter } from 'astro:transitions';
import { cachedEvents } from '../data/cached-events.ts';
import { EVENTS_URL } from '../data/events-url.ts';
import MobileMenu from '../components/MobileMenu.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { uiOf } from '../lib/i18n/ui-of.ts';
import { localizedUrl } from '../lib/i18n/localized-url.ts';
import { LOCALES } from '../lib/i18n/locales.ts';
import type { Locale } from '../lib/i18n/locales.ts';
import '../styles/global.css';

type Props = Readonly<{ lang: Locale; title: string; description?: string; path?: string }>;
const { lang, title, description = "What's on in Genoa — auto-collected events", path = '' } =
  Astro.props;

// Build-time boundary (AC-1.1): a failed fetch fails `astro build`.
const payload = await cachedEvents(EVENTS_URL);
const ui = await uiOf(lang);
const uiData = JSON.stringify({ lang, ui });
const alternates = LOCALES.map((loc) => ({
  loc,
  href: new URL(localizedUrl(loc, path), Astro.site).toString(),
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="hsl(28 92% 52%)" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`}
    />
    <title>{title} · Dove Go</title>
    {alternates.map(({ loc, href }) => <link rel="alternate" hreflang={loc} href={href} />)}
    <ClientRouter />
    <script is:inline>
      // No-flash theme init: preference is 'light' | 'dark' | 'system'
      // (default). 'system' resolves to the OS scheme. data-theme carries the
      // RESOLVED scheme (drives colours + the map filter); data-theme-pref
      // carries the user's choice (drives the toggle icon). The localStorage
      // key is shared across the user's project pages — pages that only accept
      // 'dark'/'light' treat 'system' as unknown and fall back to OS, which is
      // exactly what 'system' means, so behaviour stays consistent.
      (function () {
        var mq = window.matchMedia('(prefers-color-scheme: dark)');
        var pref = function () {
          var s = localStorage.getItem('theme');
          return s === 'dark' || s === 'light' || s === 'system' ? s : 'system';
        };
        var resolve = function (p) {
          return p === 'system' ? (mq.matches ? 'dark' : 'light') : p;
        };
        var apply = function (doc) {
          var p = pref();
          doc.documentElement.dataset['theme'] = resolve(p);
          doc.documentElement.dataset['themePref'] = p;
        };
        apply(document);
        document.addEventListener('astro:before-swap', function (e) {
          apply(e.newDocument);
        });
      })();
    </script>
  </head>
  <body>
    <header class="site-head">
      <p class="site-title">
        <a class="brand" href={localizedUrl(lang)} aria-label="Dove Go — home">
          <svg class="brand-mark" viewBox="0 0 32 40" width="19" height="24" aria-hidden="true">
            <path
              d="M16 1.6C8.6 1.6 2.6 7.5 2.6 14.9 2.6 24.4 16 38.4 16 38.4S29.4 24.4 29.4 14.9C29.4 7.5 23.4 1.6 16 1.6Z"
              fill="var(--brand)"
            ></path>
            <path
              d="M8.2 16.4C10.7 12.7 13.6 12.7 16 16.4 18.4 20.1 21.3 20.1 23.8 16.4"
              fill="none"
              stroke="#fff"
              stroke-width="2.7"
              stroke-linecap="round"
            ></path>
          </svg>
          <span class="brand-word">Dove <span class="brand-go">Go</span></span>
        </a>
      </p>
      <nav aria-label="Site">
        <a href={localizedUrl(lang)}>{ui.nav.feed}</a>
        <a href={localizedUrl(lang, 'calendar/')}>{ui.nav.calendar}</a>
        <a href={localizedUrl(lang, 'map/')}>{ui.nav.map}</a>
        <a href="https://t.me/liguria_events_bot" rel="noopener">{ui.nav.bot}</a>
        <a
          href="https://liguria-events-bot.igor-ganov.workers.dev/calendar.ics"
          rel="noopener">{ui.nav.ical}</a
        >
        <LanguageSwitcher lang={lang} path={path} />
        <ThemeToggle ui={ui} />
        <span class="account" data-account></span>
      </nav>
    </header>
    <script is:inline type="application/json" id="events-data" set:html={JSON.stringify(payload.events)} />
    <script is:inline type="application/json" id="ui-data" set:html={uiData} />
    <main>
      <slot />
    </main>
    <MobileMenu lang={lang} path={path} />
    <footer class="site-foot">
      <p>
        {ui.footer} · data as of {payload.generatedAt.slice(0, 16)}Z ·
        <a href="https://github.com/igor-ganov/liguria-events-site" rel="noopener">source</a>
      </p>
      <p class="foot-legal">
        <a href="/content-policy">Content policy</a> ·
        <a href="/terms">Terms</a> ·
        <a href="/privacy">Privacy</a>
      </p>
    </footer>

    <dialog id="signin-dialog" class="signin-dialog" aria-label="Sign in">
      <form method="dialog" class="signin-x-row">
        <button class="signin-x" value="close" aria-label="Close">✕</button>
      </form>
      <h2>Sign in to Dove Go</h2>
      <p>Enter your email and we'll send you a one-time sign-in link.</p>
      <form id="signin-form">
        <input type="email" name="email" required placeholder="you@example.com" autocomplete="email" autofocus />
        <button type="submit">Send me a link</button>
      </form>
      <p id="signin-status" role="status" aria-live="polite"></p>
    </dialog>
    <script>
      // Three-way theme cycle (light → dark → system) with circular reveal;
      // re-bound after SPA swap. data-theme = resolved scheme, data-theme-pref
      // = user choice.
      const html = document.documentElement;
      const mq = window.matchMedia('(prefers-color-scheme: dark)');
      const NEXT: Record<string, string> = { light: 'dark', dark: 'system', system: 'light' };
      const NAME_KEY: Record<string, string> = {
        light: 'nameLight',
        dark: 'nameDark',
        system: 'nameSystem',
      };
      const resolve = (pref: string): string =>
        pref === 'system' ? (mq.matches ? 'dark' : 'light') : pref;
      // Relabel every toggle with the current mode (aria + visible menu label).
      const syncButtons = (pref: string): void => {
        document.querySelectorAll<HTMLElement>('[data-theme-toggle]').forEach((btn) => {
          const name = btn.dataset[NAME_KEY[pref] ?? 'nameSystem'] ?? pref;
          btn.setAttribute('aria-label', `${btn.dataset['label'] ?? ''} (${name})`);
          const label = btn.querySelector<HTMLElement>('[data-theme-name]');
          if (label) label.textContent = name;
        });
      };
      const applyPref = (pref: string): void => {
        html.dataset['theme'] = resolve(pref);
        html.dataset['themePref'] = pref;
        localStorage.setItem('theme', pref);
        syncButtons(pref);
      };
      const cycle = (event: MouseEvent): void => {
        const pref = NEXT[html.dataset['themePref'] ?? 'system'] ?? 'light';
        if (!document.startViewTransition) {
          applyPref(pref);
          return;
        }
        const { clientX: x, clientY: y } = event;
        const r = Math.hypot(Math.max(x, innerWidth - x), Math.max(y, innerHeight - y));
        html.style.setProperty('--x', `${x}px`);
        html.style.setProperty('--y', `${y}px`);
        html.style.setProperty('--r', `${r}px`);
        document.startViewTransition({ update: () => applyPref(pref), types: ['theme'] });
      };
      // While on 'system', follow live OS scheme changes (no reveal).
      mq.addEventListener('change', () => {
        if (html.dataset['themePref'] === 'system') html.dataset['theme'] = resolve('system');
      });
      const bind = (): void => {
        document.querySelectorAll<HTMLElement>('[data-theme-toggle]').forEach((btn) => {
          if (btn.dataset['themeBound'] === 'true') return;
          btn.dataset['themeBound'] = 'true';
          btn.addEventListener('click', cycle);
        });
        syncButtons(html.dataset['themePref'] ?? 'system');
      };
      bind();
      document.addEventListener('astro:after-swap', bind);
    </script>

    <script>
      // Sign-in dialog + header account state. The header is static, so login
      // state is resolved client-side; the dialog means no /login URL ever
      // enters history. Re-run after SPA swaps (DOM is replaced).
      type Me = { user: { handle: string; role: string } | null };

      const signOut = async (): Promise<void> => {
        await fetch('/api/auth/logout', { method: 'POST' });
        location.href = '/';
      };

      const renderAccount = (user: Me['user']): void => {
        const slot = document.querySelector('[data-account]');
        if (!slot) return;
        if (user) {
          slot.innerHTML =
            '<a class="account-submit" href="/submit">+ Add event</a>' +
            `<span class="account-handle">@${user.handle}</span>` +
            '<button type="button" class="account-signout" data-signout>Sign out</button>';
          slot.querySelector('[data-signout]')?.addEventListener('click', signOut);
        } else {
          slot.innerHTML = '<button type="button" class="account-signin" data-signin>Sign in</button>';
          slot.querySelector('[data-signin]')?.addEventListener('click', () =>
            document.querySelector<HTMLDialogElement>('#signin-dialog')?.showModal(),
          );
        }
      };

      const refreshAccount = async (): Promise<void> => {
        try {
          const res = await fetch('/api/auth/me', { headers: { accept: 'application/json' } });
          renderAccount(((await res.json()) as Me).user);
        } catch {
          renderAccount(null);
        }
      };

      const bindSignin = (): void => {
        const form = document.querySelector<HTMLFormElement>('#signin-form');
        const status = document.querySelector('#signin-status');
        if (!form || form.dataset['bound'] === 'true') return;
        form.dataset['bound'] = 'true';
        form.addEventListener('submit', async (event) => {
          event.preventDefault();
          const email = new FormData(form).get('email');
          if (status) status.textContent = 'Sending…';
          const res = await fetch('/api/auth/request', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ email }),
          });
          if (status)
            status.textContent = res.ok
              ? '✓ Check your inbox for the sign-in link (expires in 5 minutes).'
              : 'Something went wrong — please try again.';
        });
      };

      const initAuthUi = (): void => {
        bindSignin();
        void refreshAccount();
        if (new URLSearchParams(location.search).has('signin'))
          document.querySelector<HTMLDialogElement>('#signin-dialog')?.showModal();
      };
      initAuthUi();
      document.addEventListener('astro:after-swap', initAuthUi);
    </script>
  </body>
</html>
