---
import Layout from '../../layouts/Layout.astro';
import { uiOf } from '../../lib/i18n/ui-of.ts';
import { CATEGORIES } from '../../lib/events/categories.ts';
import { iconSvg } from '../../lib/icons/icon-svg.ts';
import { uiIcon } from '../../lib/icons/ui-icon.ts';
import type { Locale } from '../../lib/i18n/locales.ts';

type Props = Readonly<{ lang: Locale; region: string }>;
const { lang, region } = Astro.props;
const ui = await uiOf(lang);
---

<Layout lang={lang} region={region} title={ui.nav.map} path={`${region}/map/`} needsEvents>
  <!-- The map carries every event in the country and merely opens on the region:
       pan or zoom out and the rest are already there. -->
  <script is:inline set:html={`window.__REGION__=${JSON.stringify(region)}`} />
  <link rel="preconnect" href="https://tiles.dovego.it" crossorigin />
  <h1 class="visually-hidden">{ui.nav.map}</h1>
  <div class="map-filters">
    <div class="map-layers" role="group" aria-label="Map layers">
      <button class="chip chip--layer" data-map-events aria-pressed="true"><Fragment set:html={uiIcon('ticket', 15)} /> {ui.mapLayers.events}</button>
      <button class="chip chip--layer" data-map-landmarks aria-pressed="false"><Fragment set:html={uiIcon('pin', 15)} /> {ui.mapLayers.landmarks}</button>
    </div>
    <div class="map-dates" data-map-event-filters>
      <label>{ui.range.from} <input type="date" data-map-from /></label>
      <label>{ui.range.to} <input type="date" data-map-to /></label>
    </div>
    <div class="chips" role="group" aria-label="Filter by category" data-map-event-chips>
      {
        CATEGORIES.map((category) => (
          <button class="chip" data-cat={category} data-map-cat={category} aria-pressed="false">
            <Fragment set:html={iconSvg(category, 14)} />
            {ui.cat[category]}
          </button>
        ))
      }
      <button class="chip chip--free" data-map-free aria-pressed="false">{ui.chips.free}</button>
      <button class="chip chip--gems" data-map-gems aria-pressed="false">{ui.chips.gems}</button>
      <button class="chip chip--clear" data-map-clear hidden>✕ {ui.chips.clear}</button>
    </div>
  </div>
  <div class="map-canvas" data-map-canvas>
    <div class="map-retry" data-map-retry hidden>
      <p>The map couldn't load — check your connection.</p>
      <button type="button" data-map-reload>Retry</button>
    </div>
  </div>
</Layout>

<script>
  import maplibregl from 'maplibre-gl';
  import 'maplibre-gl/dist/maplibre-gl.css';
  import { Protocol } from 'pmtiles';
  import Supercluster from 'supercluster';
  import brightStyle from '../../lib/map/styles/bright.json';
  import darkStyle from '../../lib/map/styles/dark.json';
  import { inMapArea } from '../../lib/map/in-map-area.ts';
  import { mapEvents } from '../../lib/events/map-events.ts';
  import { categoryColor } from '../../lib/events/category-color.ts';
  import { primaryCategory } from '../../lib/events/primary-category.ts';
  import { titleOf } from '../../lib/events/title-of.ts';
  import { formatWhen } from '../../lib/events/format-when.ts';
  import { eventPath } from '../../lib/event-path.ts';
  import { iconSvg } from '../../lib/icons/icon-svg.ts';
  import { localizedUrl } from '../../lib/i18n/localized-url.ts';
  import { wfsUrl } from '../../lib/civic/wfs-url.ts';
  import { tilesInBbox } from '../../lib/civic/tiles-in-bbox.ts';
  import { readEventsIsland } from '../../components/shared/read-events-island.ts';
  import { readUiIsland } from '../../components/shared/read-ui-island.ts';
  import { isoToday } from '../../lib/calendar/iso-today.ts';
  import { loadLandmarks } from '../../lib/landmarks/load-landmarks.ts';
  import { landmarkColor } from '../../lib/landmarks/landmark-color.ts';
  import { landmarkIcon } from '../../lib/landmarks/landmark-icon.ts';
  import { landmarkPath } from '../../lib/landmarks/landmark-path.ts';
  import type { Category } from '../../lib/events/categories.ts';
  import type { CompactEvent } from '../../lib/events/event-schema.ts';
  import type { Landmark } from '../../lib/landmarks/landmark-schema.ts';

  const ATTR = '© OpenMapTiles © OpenStreetMap contributors';
  const B = import.meta.env.BASE_URL.replace(/\/$/, '');
  const esc = (s: string): string =>
    s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');

  // 'light' = OSM Bright (colourful, high contrast); 'dark' = retuned Dark Matter.
  const STYLES: Record<string, unknown> = { light: brightStyle, dark: darkStyle };

  // The basemap can't be a Worker asset (25 MiB cap), so its host is
  // configurable. It covers all of Italy — panning past Liguria used to leave
  // the canvas blank, because the old extract stopped at the region border.
  const PMTILES_URL =
    import.meta.env.PUBLIC_PMTILES_URL ?? `${location.origin}${B}/tiles/italy.pmtiles`;

  const buildStyle = (key: string): maplibregl.StyleSpecification => {
    const dark = key === 'dark';
    const style = structuredClone(STYLES[key] ?? brightStyle) as maplibregl.StyleSpecification;
    style.sources = {
      openmaptiles: { type: 'vector', url: `pmtiles://${PMTILES_URL}`, attribution: ATTR },
    };
    style.glyphs = `${B}/font/{fontstack}/{range}.pbf`;
    // Light uses OSM Bright's sprite (dark Maki POI icons read on a light map);
    // dark uses a white-recoloured copy of it (poi-dark) so the same standard
    // icons stay legible on the dark basemap.
    // maplibre-gl 5 requires an ABSOLUTE sprite URL (root-relative fails).
    style.sprite = `${location.origin}${B}/sprite/poi-color/sprite`;
    // Point every label at our self-hosted glyph folders (hyphenated, no spaces
    // — GitHub Pages 404s spaced paths). Known Noto faces map to their folder;
    // anything else (Dark Matter's maptiler fonts) falls back to Regular.
    const glyphFont = (font: string): string =>
      /^noto sans (regular|bold|italic)$/i.test(font)
        ? font.toLowerCase().replace(/\s+/g, '-')
        : 'noto-sans-regular';
    for (const layer of style.layers) {
      const layout = (layer as { layout?: { 'text-font'?: readonly string[] } }).layout;
      if (layout && Array.isArray(layout['text-font'])) {
        // A self-hosted glyph folder is a SINGLE face — collapse the stack to
        // one font (comma-joined stacks like "a,b" 404 against a one-face dir).
        layout['text-font'] = [glyphFont(layout['text-font'][0] ?? 'Noto Sans Regular')];
      }
    }
    const layers = style.layers as unknown as Array<Record<string, unknown>>;
    // Dark Matter's roads stay subtle even after retuning; add a brighter
    // major-road overlay so highways read clearly. (Light/OSM Bright is fine.)
    if (dark) {
      const roadHi = {
        id: 'road-highlight',
        type: 'line',
        source: 'openmaptiles',
        'source-layer': 'transportation',
        filter: ['in', ['get', 'class'], ['literal', ['motorway', 'trunk', 'primary', 'secondary', 'tertiary']]],
        layout: { 'line-cap': 'round', 'line-join': 'round' },
        paint: {
          'line-color': '#c0c6cf',
          'line-width': ['interpolate', ['linear'], ['zoom'], 7, 0.6, 11, 2, 15, 4.6],
          'line-opacity': 0.9,
        },
      };
      const symAt = layers.findIndex((l) => l['type'] === 'symbol');
      layers.splice(symAt >= 0 ? symAt : layers.length, 0, roadHi);
    }
    return style;
  };

  type EvProps = { ev: CompactEvent };

  // The live map, tracked so we can release its WebGL context on SPA nav —
  // otherwise each visit leaks a context and the browser eventually drops one,
  // leaving a blank basemap under the (DOM) markers.
  let activeMap: maplibregl.Map | undefined;

  const setup = (): void => {
    const canvas = document.querySelector<HTMLElement>('[data-map-canvas]');
    if (!canvas || canvas.dataset['ready'] === 'true') return;
    canvas.dataset['ready'] = 'true';

    maplibregl.addProtocol('pmtiles', new Protocol().tile);
    const events = readEventsIsland();
    const { lang, ui } = readUiIsland();
    const href = (e: CompactEvent): string => localizedUrl(lang, eventPath(e.id));
    const thumb = (e: CompactEvent): string =>
      e.img ? `<img src="${e.img}" alt="" loading="lazy" referrerpolicy="no-referrer" />` : '';

    const today = isoToday();
    const sorted = [today, ...events.map((e) => e.e ?? e.s)].sort();
    const maxDate = sorted[sorted.length - 1] ?? today;
    // Upper bound is open by default ("until the very end") and clearable.
    // Two opt-in layers: events show by default; landmarks are off until asked
    // for. Both, either or neither can be on — the toggles are independent.
    const lsBool = (key: string, fallback: boolean): boolean => {
      const v = localStorage.getItem(key);
      return v === null ? fallback : v === '1';
    };
    const state = {
      from: today, to: '', selected: new Set<Category>(), freeOnly: false, gemsOnly: false,
      showEvents: lsBool('map-layer-events', true),
      showLandmarks: lsBool('map-layer-landmarks', false),
    };

    // The view the visitor left: "?z=11.4&c=44.4123,8.9312". It goes in the
    // QUERY, not the hash — maplibre's own `hash` option writes one, but Astro's
    // client router drops it on a back navigation, while the query survives.
    type View = Readonly<{ zoom: number; lat: number; lng: number }>;
    let saved: View | undefined;

    const readView = (p: URLSearchParams): View | undefined => {
      const zoom = Number(p.get('z'));
      const [lat, lng] = (p.get('c') ?? '').split(',').map(Number);
      const ok =
        Number.isFinite(zoom) && Number.isFinite(lat) && Number.isFinite(lng) && p.has('z');
      return ok ? { zoom, lat: lat as number, lng: lng as number } : undefined;
    };

    const readUrl = (): void => {
      const p = new URLSearchParams(location.search);
      (p.get('cat') ?? '').split(',').filter(Boolean).forEach((c) => state.selected.add(c as Category));
      state.freeOnly = p.get('free') === '1';
      state.gemsOnly = p.get('gems') === '1';
      state.from = p.get('from') ?? today;
      state.to = p.get('to') ?? '';
      if (p.has('ev')) state.showEvents = p.get('ev') !== '0';
      if (p.has('le')) state.showLandmarks = p.get('le') === '1';
      saved = readView(p);
    };
    const writeUrl = (): void => {
      const p = new URLSearchParams();
      if (state.selected.size > 0) p.set('cat', [...state.selected].join(','));
      if (state.freeOnly) p.set('free', '1');
      if (state.gemsOnly) p.set('gems', '1');
      if (state.from !== today) p.set('from', state.from);
      if (state.to !== '') p.set('to', state.to);
      if (!state.showEvents) p.set('ev', '0');
      if (state.showLandmarks) p.set('le', '1');
      localStorage.setItem('map-layer-events', state.showEvents ? '1' : '0');
      localStorage.setItem('map-layer-landmarks', state.showLandmarks ? '1' : '0');
      const view = activeMap;
      if (view !== undefined) {
        const centre = view.getCenter();
        p.set('z', view.getZoom().toFixed(2));
        p.set('c', `${centre.lat.toFixed(4)},${centre.lng.toFixed(4)}`);
      }
      const qs = p.toString();
      history.replaceState(history.state, '', qs ? `${location.pathname}?${qs}` : location.pathname);
    };
    readUrl();

    // The basemap simply follows the site theme (no switcher): light theme →
    // light map, dark theme → dark map, live.
    const isDark = (): boolean => document.documentElement.dataset['theme'] === 'dark';
    const resolvedKey = (): string => (isDark() ? 'dark' : 'light');
    const map = new maplibregl.Map({
      container: canvas,
      style: buildStyle(resolvedKey()),
      // The view the visitor left, when they left one — so coming back from an
      // event opens on the map they were looking at, not on the region again.
      center: saved === undefined ? [8.93, 44.41] : [saved.lng, saved.lat],
      zoom: saved?.zoom ?? 9,
      attributionControl: false,
    });
    activeMap = map;
    map.addControl(new maplibregl.AttributionControl({ compact: true, customAttribution: ATTR }));
    map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-left');

    // "Where am I" — a plain button that is ALWAYS clickable and prompts for
    // geolocation on click. Gives feedback (loading / toast) because the
    // basemap stops at the Italian border.
    const MSG: Record<string, Record<string, string>> = {
      outside: {
        en: 'You are outside the map area (Genoa / Liguria).',
        it: 'Sei fuori dall’area della mappa (Genova / Liguria).',
        ru: 'Вы вне области карты (Генуя / Лигурия).',
      },
      denied: {
        en: 'Location access is blocked — allow it in the browser.',
        it: 'Accesso alla posizione bloccato — consentilo nel browser.',
        ru: 'Доступ к геолокации запрещён — разрешите его в браузере.',
      },
      error: {
        en: 'Could not determine your location.',
        it: 'Impossibile determinare la posizione.',
        ru: 'Не удалось определить местоположение.',
      },
    };
    const say = (key: string): void => {
      const el = document.createElement('div');
      el.className = 'map-toast';
      el.textContent = MSG[key]?.[lang] ?? MSG[key]?.['en'] ?? '';
      canvas.appendChild(el);
      setTimeout(() => el.remove(), 4200);
    };
    let meMarker: maplibregl.Marker | undefined;
    const locateBtn = document.createElement('button');
    const requestPosition = (): void => {
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          locateBtn.classList.remove('map-locate-btn--busy');
          const at: [number, number] = [pos.coords.longitude, pos.coords.latitude];
          if (meMarker) {
            meMarker.setLngLat(at);
          } else {
            const dot = document.createElement('div');
            dot.className = 'map-me';
            meMarker = new maplibregl.Marker({ element: dot }).setLngLat(at).addTo(map);
          }
          if (inMapArea(at[0], at[1])) {
            map.easeTo({ center: at, zoom: Math.max(map.getZoom(), 14) });
          } else {
            say('outside');
          }
        },
        (err) => {
          locateBtn.classList.remove('map-locate-btn--busy');
          say(err.code === err.PERMISSION_DENIED ? 'denied' : 'error');
        },
        { enableHighAccuracy: true, timeout: 9000, maximumAge: 60000 },
      );
    };
    const locate = (): void => {
      if (!navigator.geolocation) {
        say('error');
        return;
      }
      locateBtn.classList.add('map-locate-btn--busy');
      // Call getCurrentPosition SYNCHRONOUSLY inside the click handler: browsers
      // only raise the permission prompt from within the user gesture, so any
      // await/.then() before this call would suppress it. A previously-denied
      // origin lands in the error callback (code 1) → the "blocked" message.
      requestPosition();
    };
    const locateControl = {
      onAdd(): HTMLElement {
        const wrap = document.createElement('div');
        wrap.className = 'maplibregl-ctrl maplibregl-ctrl-group';
        locateBtn.type = 'button';
        locateBtn.className = 'map-locate-btn';
        locateBtn.title = 'Find my location';
        locateBtn.setAttribute('aria-label', 'Find my location');
        locateBtn.innerHTML =
          '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3.2"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/></svg>';
        locateBtn.addEventListener('click', locate);
        wrap.appendChild(locateBtn);
        return wrap;
      },
      onRemove(): void {
        /* nothing to tear down */
      },
    };
    map.addControl(locateControl, 'top-left');

    // Follow the site theme live (data-theme is rewritten by the theme script,
    // incl. OS changes under 'system'). DOM photo markers survive setStyle.
    let loadedKey = resolvedKey();
    new MutationObserver(() => {
      const key = resolvedKey();
      if (key === loadedKey) return;
      loadedKey = key;
      map.setStyle(buildStyle(key));
      // DOM markers (events + landmarks) survive setStyle; only the civici
      // GeoJSON layer has to be re-added.
      map.once('styledata', () => restoreCivics());
    }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    // ── popups ────────────────────────────────────────────────────────────────
    const openEvent = (e: CompactEvent, at: [number, number]): void => {
      new maplibregl.Popup({ closeButton: false, maxWidth: '260px', anchor: 'bottom', offset: 26 })
        .setLngLat(at)
        .setHTML(
          `<a class="map-pop" href="${href(e)}"><span class="map-pop-thumb">${thumb(e)}</span>` +
            `<span class="map-pop-title">${esc(titleOf(lang)(e))}</span>` +
            `<span class="map-pop-when">${esc(formatWhen(e))}</span></a>`,
        )
        .addTo(map);
    };
    const openCluster = (leaves: readonly CompactEvent[], at: [number, number]): void => {
      const rows = leaves
        .map(
          (e) =>
            `<a class="map-clus-row" href="${href(e)}"><span class="map-clus-thumb">${thumb(e)}</span>` +
            `<span class="map-clus-text"><span class="map-clus-title">${esc(titleOf(lang)(e))}</span>` +
            `<span class="map-pop-when">${esc(formatWhen(e))}</span></span></a>`,
        )
        .join('');
      new maplibregl.Popup({ closeButton: true, maxWidth: '300px', anchor: 'bottom', offset: 26, className: 'map-clus-popup' })
        .setLngLat(at)
        .setHTML(`<div class="map-clus-card"><div class="map-clus-head">${leaves.length}</div><div class="map-clus-list">${rows}</div></div>`)
        .addTo(map);
    };

    // ── markers (square photo) + cluster plaques ────────────────────────────────
    const eventMarkerEl = (e: CompactEvent): HTMLElement => {
      const el = document.createElement('div');
      el.className = 'ev-marker';
      el.style.setProperty('--c', categoryColor(primaryCategory(e.c)));
      const face = document.createElement('div');
      face.className = 'ev-marker-face';
      if (e.img) {
        const img = document.createElement('img');
        img.src = e.img;
        img.loading = 'lazy';
        img.referrerPolicy = 'no-referrer';
        img.alt = '';
        face.appendChild(img);
      } else {
        face.classList.add('ev-marker-face--icon');
        face.innerHTML = iconSvg(primaryCategory(e.c), 22);
      }
      el.appendChild(face);
      return el;
    };
    const clusterMarkerEl = (count: number): HTMLElement => {
      const el = document.createElement('div');
      el.className = 'ev-marker ev-cluster';
      el.innerHTML = `<div class="ev-cluster-face"><span>${count}</span></div>`;
      return el;
    };

    let index: Supercluster<EvProps> | undefined;
    const rebuildIndex = (): void => {
      const shown = mapEvents(state.from, state.to, [...state.selected], state.freeOnly, state.gemsOnly)(events);
      index = new Supercluster<EvProps>({ radius: 60, maxZoom: 15 });
      index.load(
        shown
          .filter((e) => e.g !== undefined)
          .map((e) => ({
            type: 'Feature',
            properties: { ev: e },
            geometry: { type: 'Point', coordinates: [e.g![1], e.g![0]] },
          })),
      );
    };

    const markers: maplibregl.Marker[] = [];
    const render = (): void => {
      markers.forEach((m) => m.remove());
      markers.length = 0;
      if (!index || !state.showEvents) return;
      const b = map.getBounds();
      const clusters = index.getClusters(
        [b.getWest(), b.getSouth(), b.getEast(), b.getNorth()],
        Math.round(map.getZoom()),
      );
      clusters.forEach((c) => {
        const at = c.geometry.coordinates as [number, number];
        const props = c.properties as { cluster?: boolean; cluster_id?: number; point_count?: number } & EvProps;
        if (props.cluster) {
          const el = clusterMarkerEl(props.point_count ?? 0);
          el.addEventListener('click', (ev) => {
            ev.stopPropagation();
            const leaves = (index?.getLeaves(props.cluster_id ?? 0, Infinity) ?? []).map((l) => (l.properties as EvProps).ev);
            openCluster(leaves, at);
          });
          markers.push(new maplibregl.Marker({ element: el, anchor: 'bottom' }).setLngLat(at).addTo(map));
        } else {
          const e = props.ev;
          const el = eventMarkerEl(e);
          el.addEventListener('click', (ev) => {
            ev.stopPropagation();
            openEvent(e, at);
          });
          markers.push(new maplibregl.Marker({ element: el, anchor: 'bottom' }).setLngLat(at).addTo(map));
        }
      });
    };

    // Open on the region named in the URL, but hold the whole country: pan or
    // zoom out and every other region's pins are already in the layer.
    const REGION = (globalThis as { __REGION__?: string }).__REGION__;
    let fitted = false;
    const fitAll = (): void => {
      const visible = mapEvents(state.from, state.to, [...state.selected], state.freeOnly, state.gemsOnly)(events).filter(
        (e) => e.g !== undefined,
      );
      const home = visible.filter((e) => (e.rg ?? 'liguria') === REGION);
      const located = home.length > 0 ? home : visible;
      // A view carried in from the URL is the one the visitor left; fitting the
      // region's events over it would throw it away.
      if (fitted || saved !== undefined || located.length === 0) return;
      // One mis-geocoded event used to drag the opening view across half the
      // country. Fit to the body of the region's events, not to their extremes.
      const median = (xs: readonly number[]): number =>
        xs.toSorted((a, b) => a - b)[Math.floor(xs.length / 2)] ?? 0;
      const mLat = median(located.map((e) => e.g![0]));
      const mLng = median(located.map((e) => e.g![1]));
      const core = located.filter(
        (e) => Math.abs(e.g![0] - mLat) < 1.2 && Math.abs(e.g![1] - mLng) < 1.6,
      );
      const bounds = new maplibregl.LngLatBounds();
      (core.length > 0 ? core : located).forEach((e) => bounds.extend([e.g![1], e.g![0]]));
      map.fitBounds(bounds, { padding: 60, maxZoom: 13, duration: 0 });
      fitted = true;
    };

    canvas.dataset['loading'] = 'true';
    const retryEl = document.querySelector<HTMLElement>('[data-map-retry]');
    let loaded = false;
    // On a slow link, reveal the map after a few seconds (DOM markers show, base
    // tiles stream in) rather than blocking on full tile load; only surface a
    // Retry if the map truly never comes up.
    const softReveal = setTimeout(() => {
      if (!loaded) canvas.dataset['loading'] = 'false';
    }, 9000);
    const hardFail = setTimeout(() => {
      if (!loaded) {
        canvas.dataset['loading'] = 'false';
        retryEl?.removeAttribute('hidden');
      }
    }, 30000);
    map.on('load', () => {
      loaded = true;
      clearTimeout(softReveal);
      clearTimeout(hardFail);
      canvas.dataset['loading'] = 'false';
      retryEl?.setAttribute('hidden', '');
      rebuildIndex();
      fitAll();
      render();
    });
    document.querySelector('[data-map-reload]')?.addEventListener('click', () => location.reload());
    // Every pan and zoom lands in the address bar, so the history entry the
    // visitor leaves behind already holds the map they were looking at.
    map.on('moveend', () => {
      render();
      writeUrl();
    });

    // ── civici: Genoa comune WFS address numbers (cadastre) at street zoom ──
    // Commercial (COLORE=R) get a shop icon + red number; residential a marker
    // + neutral number. Streamed per viewport tile with a session cache.
    const CIVIC_MINZOOM = 16.5;
    const civicFeatures: GeoJSON.Feature[] = [];
    const civicSeen = new Set<string>();
    const civicData = (): GeoJSON.FeatureCollection => ({ type: 'FeatureCollection', features: civicFeatures });
    const restoreCivics = (): void => {
      if (map.getSource('civics')) return;
      map.addSource('civics', { type: 'geojson', data: civicData() });
      map.addLayer({
        id: 'civics',
        type: 'symbol',
        source: 'civics',
        minzoom: CIVIC_MINZOOM,
        layout: {
          'icon-image': ['case', ['==', ['get', 'COLORE'], 'R'], 'shop_11', 'marker_11'],
          'icon-size': 0.9,
          'icon-optional': true,
          'text-field': ['get', 'TESTO'],
          'text-font': ['noto-sans-bold'],
          'text-size': 10,
          'text-offset': [0, 0.9],
          'text-anchor': 'top',
          'text-optional': true,
        },
        paint: {
          'text-color': ['case', ['==', ['get', 'COLORE'], 'R'], '#d1483f', isDark() ? '#c6ccd6' : '#33404f'],
          'text-halo-color': isDark() ? '#12151c' : '#ffffff',
          'text-halo-width': 1.1,
        },
      } as maplibregl.LayerSpecification);
    };
    const loadCivics = async (): Promise<void> => {
      if (map.getZoom() < CIVIC_MINZOOM) return;
      restoreCivics();
      const b = map.getBounds();
      const fresh = tilesInBbox(b.getWest(), b.getSouth(), b.getEast(), b.getNorth())
        .filter(([key]) => !civicSeen.has(key))
        .slice(0, 12);
      await Promise.all(
        fresh.map(async ([key, bbox]) => {
          civicSeen.add(key);
          try {
            const res = await fetch(wfsUrl(bbox));
            const json = (await res.json()) as { features?: readonly GeoJSON.Feature[] };
            for (const feature of json.features ?? []) civicFeatures.push(feature);
          } catch {
            /* skip a failed tile */
          }
        }),
      );
      const src = map.getSource('civics') as maplibregl.GeoJSONSource | undefined;
      if (src) src.setData(civicData());
    };
    map.on('load', () => void loadCivics());
    map.on('moveend', () => void loadCivics());

    // ── landmarks: an opt-in layer of photo markers, like the events ────────────
    // Same supercluster + DOM-marker approach as events (only the in-view,
    // unclustered points become photo tiles), but ROUND — so the heritage layer
    // reads distinctly from the square event markers. A marker's card links to
    // the landmark's own page, where Wikipedia sits under Sources.
    type LmProps = { l: Landmark };
    let landmarkData: readonly Landmark[] | undefined;
    let lmIndex: Supercluster<LmProps> | undefined;
    const lmMarkers: maplibregl.Marker[] = [];
    const landmarkHref = (l: Landmark): string => localizedUrl(lang, landmarkPath(l.id));
    // Commons/Wikipedia thumbs default to ~800px; ask for a marker-sized one.
    const thumbUrl = (url: string, px: number): string =>
      url.replace(/([?&]width=)\d+/, `$1${px}`).replace(/\/\d+px-/, `/${px}px-`);

    const landmarkMarkerEl = (l: Landmark): HTMLElement => {
      const el = document.createElement('div');
      el.className = 'lm-marker';
      el.style.setProperty('--lm', landmarkColor(l.kind));
      const face = document.createElement('div');
      face.className = 'lm-marker-face';
      if (l.img) {
        const img = document.createElement('img');
        img.src = thumbUrl(l.img, 96);
        img.loading = 'lazy';
        img.referrerPolicy = 'no-referrer';
        img.alt = '';
        face.appendChild(img);
      } else {
        face.classList.add('lm-marker-face--icon');
        face.innerHTML = landmarkIcon(l.kind, 20);
      }
      el.appendChild(face);
      return el;
    };
    const lmClusterEl = (count: number): HTMLElement => {
      const el = document.createElement('div');
      el.className = 'lm-marker lm-cluster';
      el.innerHTML = `<div class="lm-cluster-face"><span>${count}</span></div>`;
      return el;
    };
    const openLandmarkPopup = (l: Landmark, at: [number, number]): void => {
      const kindLabel = ui.landmarks.kinds[l.kind] ?? l.kind;
      const img = l.img
        ? `<span class="map-pop-thumb"><img src="${esc(thumbUrl(l.img, 240))}" alt="" loading="lazy" referrerpolicy="no-referrer" /></span>`
        : '';
      new maplibregl.Popup({ closeButton: false, maxWidth: '250px', anchor: 'bottom', offset: 24, className: 'lm-popup' })
        .setLngLat(at)
        .setHTML(
          `<a class="map-pop" href="${esc(landmarkHref(l))}">${img}` +
            `<span class="lm-pop-kind" style="--lm:${landmarkColor(l.kind)}">${landmarkIcon(l.kind, 13)} ${esc(kindLabel)}</span>` +
            `<span class="map-pop-title">${esc(l.name)}</span></a>`,
        )
        .addTo(map);
    };

    const rebuildLmIndex = (): void => {
      if (!landmarkData) return;
      lmIndex = new Supercluster<LmProps>({ radius: 60, maxZoom: 16 });
      lmIndex.load(
        landmarkData.map((l) => ({
          type: 'Feature',
          properties: { l },
          geometry: { type: 'Point', coordinates: [l.lng, l.lat] },
        })),
      );
    };
    const renderLandmarks = (): void => {
      lmMarkers.forEach((m) => m.remove());
      lmMarkers.length = 0;
      if (!lmIndex || !state.showLandmarks) return;
      const b = map.getBounds();
      const clusters = lmIndex.getClusters(
        [b.getWest(), b.getSouth(), b.getEast(), b.getNorth()],
        Math.round(map.getZoom()),
      );
      clusters.forEach((c) => {
        const at = c.geometry.coordinates as [number, number];
        const props = c.properties as { cluster?: boolean; cluster_id?: number; point_count?: number } & Partial<LmProps>;
        if (props.cluster) {
          const el = lmClusterEl(props.point_count ?? 0);
          el.addEventListener('click', (ev) => {
            ev.stopPropagation();
            const zoom = lmIndex?.getClusterExpansionZoom(props.cluster_id ?? 0) ?? map.getZoom() + 2;
            map.easeTo({ center: at, zoom });
          });
          lmMarkers.push(new maplibregl.Marker({ element: el, anchor: 'center' }).setLngLat(at).addTo(map));
        } else {
          const l = (props as LmProps).l;
          const el = landmarkMarkerEl(l);
          el.addEventListener('click', (ev) => {
            ev.stopPropagation();
            openLandmarkPopup(l, at);
          });
          lmMarkers.push(new maplibregl.Marker({ element: el, anchor: 'center' }).setLngLat(at).addTo(map));
        }
      });
    };
    const hideLandmarks = (): void => {
      lmMarkers.forEach((m) => m.remove());
      lmMarkers.length = 0;
    };
    const showLandmarkLayer = async (): Promise<void> => {
      if (!landmarkData) {
        landmarkData = await loadLandmarks(lang);
        rebuildLmIndex();
      }
      renderLandmarks();
    };
    map.on('load', () => { if (state.showLandmarks) void showLandmarkLayer(); });
    map.on('moveend', () => { if (state.showLandmarks) renderLandmarks(); });

    // ── controls ────────────────────────────────────────────────────────────────
    const clearEl = document.querySelector<HTMLElement>('[data-map-clear]');
    const freeEl = document.querySelector<HTMLButtonElement>('[data-map-free]');
    const gemsEl = document.querySelector<HTMLButtonElement>('[data-map-gems]');
    const catBtns = [...document.querySelectorAll<HTMLButtonElement>('[data-map-cat]')];
    const fromEl = document.querySelector<HTMLInputElement>('[data-map-from]');
    const toEl = document.querySelector<HTMLInputElement>('[data-map-to]');
    const eventsEl = document.querySelector<HTMLButtonElement>('[data-map-events]');
    const landmarksEl = document.querySelector<HTMLButtonElement>('[data-map-landmarks]');
    const eventFilterEls = [
      document.querySelector<HTMLElement>('[data-map-event-filters]'),
      document.querySelector<HTMLElement>('[data-map-event-chips]'),
    ];
    const anyFilter = (): boolean => state.selected.size > 0 || state.freeOnly || state.gemsOnly;

    // Event filters only make sense while the events layer is on; fold them away
    // when it is off so the toolbar reflects what the map is actually showing.
    const syncLayers = (): void => {
      eventsEl?.setAttribute('aria-pressed', String(state.showEvents));
      landmarksEl?.setAttribute('aria-pressed', String(state.showLandmarks));
      eventFilterEls.forEach((el) => el?.toggleAttribute('hidden', !state.showEvents));
    };

    const syncControls = (): void => {
      catBtns.forEach((b) => b.setAttribute('aria-pressed', String(state.selected.has(b.dataset['mapCat'] as Category))));
      freeEl?.setAttribute('aria-pressed', String(state.freeOnly));
      gemsEl?.setAttribute('aria-pressed', String(state.gemsOnly));
      if (fromEl) Object.assign(fromEl, { value: state.from, min: today, max: maxDate });
      if (toEl) Object.assign(toEl, { value: state.to, min: today, max: maxDate });
      if (clearEl) clearEl.hidden = !anyFilter();
    };
    const refresh = (): void => {
      writeUrl();
      syncControls();
      rebuildIndex();
      render();
    };

    catBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset['mapCat'] as Category;
        state.selected.has(cat) ? state.selected.delete(cat) : state.selected.add(cat);
        refresh();
      });
    });
    freeEl?.addEventListener('click', () => {
      state.freeOnly = !state.freeOnly;
      refresh();
    });
    gemsEl?.addEventListener('click', () => {
      state.gemsOnly = !state.gemsOnly;
      refresh();
    });
    fromEl?.addEventListener('change', () => {
      state.from = fromEl.value;
      refresh();
    });
    toEl?.addEventListener('change', () => {
      state.to = toEl.value;
      refresh();
    });
    clearEl?.addEventListener('click', () => {
      state.selected.clear();
      state.freeOnly = false;
      state.gemsOnly = false;
      refresh();
    });

    eventsEl?.addEventListener('click', () => {
      state.showEvents = !state.showEvents;
      writeUrl();
      syncLayers();
      render();
    });
    landmarksEl?.addEventListener('click', () => {
      state.showLandmarks = !state.showLandmarks;
      writeUrl();
      syncLayers();
      state.showLandmarks ? void showLandmarkLayer() : hideLandmarks();
    });

    syncControls();
    syncLayers();
  };

  setup();
  document.addEventListener('astro:after-swap', setup);
  // Release the WebGL context + listeners when leaving the page via SPA nav.
  document.addEventListener('astro:before-swap', () => {
    activeMap?.remove();
    activeMap = undefined;
  });
</script>
