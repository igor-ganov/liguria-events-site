---
import { ClientRouter } from 'astro:transitions';
import { cachedEvents } from '../data/cached-events.ts';
import { EVENTS_URL } from '../data/events-url.ts';
import MobileMenu from '../components/MobileMenu.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import RegionPicker from '../components/RegionPicker.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { uiOf } from '../lib/i18n/ui-of.ts';
import { uiIcon } from '../lib/icons/ui-icon.ts';
import { localizedUrl } from '../lib/i18n/localized-url.ts';
import { regionUrl } from '../lib/region/region-url.ts';
import { DEFAULT_REGION } from '../lib/region/default-region.ts';
import { LOCALES } from '../lib/i18n/locales.ts';
import type { Locale } from '../lib/i18n/locales.ts';
import '../styles/global.css';

type Props = Readonly<{
  lang: Locale;
  title: string;
  region?: string;
  description?: string;
  path?: string;
  needsEvents?: boolean;
}>;
const {
  lang,
  title,
  region = DEFAULT_REGION,
  description = "What's on in Italy — auto-collected events",
  path = '',
  needsEvents = false,
} = Astro.props;

// Only feed / calendar / map embed the full event list; every other page skips
// this ~44 KB (compressed) island and the build-time fetch entirely.
// `path` is "<region>/", "<region>/calendar/2026-07/" or "<region>/map/" — the
// part after the region is the page the picker keeps you on. A specific month
// collapses to the calendar index: another region may have no events that month
// and therefore no page for it.
const rest = path.split('/').slice(1).filter((part) => part !== '');
const page = rest.length === 0 ? '' : `${rest[0]}/`;
const payload = needsEvents ? await cachedEvents(EVENTS_URL) : null;
const ui = await uiOf(lang);
const uiData = JSON.stringify({ lang, ui });
const alternates = LOCALES.map((loc) => ({
  loc,
  href: new URL(localizedUrl(loc, path), Astro.site).toString(),
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="hsl(28 92% 52%)" />
    <link
      rel="icon"
      type="image/svg+xml"
      href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`}
    />
    <title>{title} · Dove Go</title>
    {alternates.map(({ loc, href }) => <link rel="alternate" hreflang={loc} href={href} />)}
    <ClientRouter />
    <script is:inline>
      // No-flash theme init: preference is 'light' | 'dark' | 'system'
      // (default). 'system' resolves to the OS scheme. data-theme carries the
      // RESOLVED scheme (drives colours + the map filter); data-theme-pref
      // carries the user's choice (drives the toggle icon). The localStorage
      // key is shared across the user's project pages — pages that only accept
      // 'dark'/'light' treat 'system' as unknown and fall back to OS, which is
      // exactly what 'system' means, so behaviour stays consistent.
      (function () {
        var mq = window.matchMedia('(prefers-color-scheme: dark)');
        var pref = function () {
          var s = localStorage.getItem('theme');
          return s === 'dark' || s === 'light' || s === 'system' ? s : 'system';
        };
        var resolve = function (p) {
          return p === 'system' ? (mq.matches ? 'dark' : 'light') : p;
        };
        var apply = function (doc) {
          var p = pref();
          doc.documentElement.dataset['theme'] = resolve(p);
          doc.documentElement.dataset['themePref'] = p;
        };
        apply(document);
        document.addEventListener('astro:before-swap', function (e) {
          apply(e.newDocument);
        });
      })();
    </script>
  </head>
  <body>
    <header class="site-head">
      <p class="site-title">
        <a class="brand" href={regionUrl(lang, region)} aria-label="Dove Go — home">
          <svg class="brand-mark" viewBox="0 0 32 40" width="19" height="24" aria-hidden="true">
            <path
              d="M16 1.6C8.6 1.6 2.6 7.5 2.6 14.9 2.6 24.4 16 38.4 16 38.4S29.4 24.4 29.4 14.9C29.4 7.5 23.4 1.6 16 1.6Z"
              fill="var(--brand)"
            ></path>
            <path
              d="M8.2 16.4C10.7 12.7 13.6 12.7 16 16.4 18.4 20.1 21.3 20.1 23.8 16.4"
              fill="none"
              stroke="#fff"
              stroke-width="2.7"
              stroke-linecap="round"
            ></path>
          </svg>
          <span class="brand-word">Dove <span class="brand-go">Go</span></span>
        </a>
      </p>
      <nav aria-label="Site">
        <a href={regionUrl(lang, region)}>{ui.nav.feed}</a>
        <a href={regionUrl(lang, region, 'calendar/')}>{ui.nav.calendar}</a>
        <a href={regionUrl(lang, region, 'map/')}>{ui.nav.map}</a>
        <a href={regionUrl(lang, region, 'landmarks/')}>{ui.nav.landmarks}</a>
        <a href={regionUrl(lang, region, 'places/')}>{ui.nav.places}</a>
        <a href="https://t.me/liguria_events_bot" rel="noopener">{ui.nav.bot}</a>
        <a
          href="https://liguria-events-bot.igor-ganov.workers.dev/calendar.ics"
          rel="noopener">{ui.nav.ical}</a
        >
        <LanguageSwitcher lang={lang} path={path} />
        <ThemeToggle ui={ui} />
        <span class="account" data-account></span>
      </nav>
      <!-- Outside the nav on purpose: the nav is hidden on a phone, and the
           region is the one control that must stay reachable everywhere. -->
      <RegionPicker lang={lang} region={region} page={page} />
    </header>
    {payload && <script is:inline type="application/json" id="events-data" set:html={JSON.stringify(payload.events)} />}
    <script is:inline type="application/json" id="ui-data" set:html={uiData} />
    <main>
      <slot />
    </main>
    <MobileMenu lang={lang} path={path} region={region} />
    <footer class="site-foot">
      <p>
        {ui.footer}{payload ? ` · data as of ${payload.generatedAt.slice(0, 16)}Z` : ''} ·
        <a href="https://github.com/igor-ganov/liguria-events-site" rel="noopener">source</a>
      </p>
      <p class="foot-legal">
        <a href="/content-policy">Content policy</a> ·
        <a href="/terms">Terms</a> ·
        <a href="/privacy">Privacy</a>
      </p>
    </footer>

    <dialog id="signin-dialog" class="signin-dialog" aria-label={ui.auth.signIn}>
      <form method="dialog" class="signin-x-row">
        <button class="signin-x" value="close" aria-label="Close">✕</button>
      </form>
      <h2>{ui.auth.title}</h2>

      <div data-step="email">
        <p>{ui.auth.emailPrompt}</p>
        <form id="signin-form">
          <input type="email" name="email" required placeholder="you@example.com" autocomplete="email" />
          <button type="submit">{ui.auth.sendCode}</button>
        </form>
        <div class="passkey-alt" data-passkey-alt hidden>
          <div class="signin-or"><span>{ui.auth.or}</span></div>
          <button type="button" id="passkey-signin" class="account-signin passkey-btn"><Fragment set:html={uiIcon('key', 16)} /> {ui.auth.passkey}</button>
        </div>
      </div>

      <div data-step="code" hidden>
        <p>{ui.auth.codePre} <strong data-code-email></strong> {ui.auth.codePost}</p>
        <form id="code-form">
          <input type="text" name="code" inputmode="numeric" autocomplete="one-time-code"
            pattern="[0-9]{6}" maxlength="6" placeholder="123456" />
          <button type="submit">{ui.auth.verify}</button>
        </form>
        <button type="button" class="link-btn" data-code-back>← {ui.auth.back}</button>
      </div>

      <p id="signin-status" role="status" aria-live="polite"></p>
    </dialog>
    <script>
      // Three-way theme cycle (light → dark → system) with circular reveal;
      // re-bound after SPA swap. data-theme = resolved scheme, data-theme-pref
      // = user choice.
      const html = document.documentElement;
      const mq = window.matchMedia('(prefers-color-scheme: dark)');
      const NEXT: Record<string, string> = { light: 'dark', dark: 'system', system: 'light' };
      const NAME_KEY: Record<string, string> = {
        light: 'nameLight',
        dark: 'nameDark',
        system: 'nameSystem',
      };
      const resolve = (pref: string): string =>
        pref === 'system' ? (mq.matches ? 'dark' : 'light') : pref;
      // Relabel every toggle with the current mode (aria + visible menu label).
      const syncButtons = (pref: string): void => {
        document.querySelectorAll<HTMLElement>('[data-theme-toggle]').forEach((btn) => {
          const name = btn.dataset[NAME_KEY[pref] ?? 'nameSystem'] ?? pref;
          btn.setAttribute('aria-label', `${btn.dataset['label'] ?? ''} (${name})`);
          const label = btn.querySelector<HTMLElement>('[data-theme-name]');
          if (label) label.textContent = name;
        });
      };
      const applyPref = (pref: string): void => {
        html.dataset['theme'] = resolve(pref);
        html.dataset['themePref'] = pref;
        localStorage.setItem('theme', pref);
        syncButtons(pref);
      };
      const cycle = (event: MouseEvent): void => {
        const pref = NEXT[html.dataset['themePref'] ?? 'system'] ?? 'light';
        if (!document.startViewTransition) {
          applyPref(pref);
          return;
        }
        const { clientX: x, clientY: y } = event;
        const r = Math.hypot(Math.max(x, innerWidth - x), Math.max(y, innerHeight - y));
        html.style.setProperty('--x', `${x}px`);
        html.style.setProperty('--y', `${y}px`);
        html.style.setProperty('--r', `${r}px`);
        document.startViewTransition({ update: () => applyPref(pref), types: ['theme'] });
      };
      // While on 'system', follow live OS scheme changes (no reveal).
      mq.addEventListener('change', () => {
        if (html.dataset['themePref'] === 'system') html.dataset['theme'] = resolve('system');
      });
      const bind = (): void => {
        document.querySelectorAll<HTMLElement>('[data-theme-toggle]').forEach((btn) => {
          if (btn.dataset['themeBound'] === 'true') return;
          btn.dataset['themeBound'] = 'true';
          btn.addEventListener('click', cycle);
        });
        syncButtons(html.dataset['themePref'] ?? 'system');
      };
      bind();
      document.addEventListener('astro:after-swap', bind);
    </script>

    <script>
      import { startAuthentication, startRegistration } from '@simplewebauthn/browser';
      import { readUiIsland } from '../components/shared/read-ui-island.ts';

      // Sign-in dialog + header account state (header is static → resolved
      // client-side). Re-run after SPA swaps (DOM is replaced).
      const auth = readUiIsland().ui.auth;
      type Me = { user: { handle: string; role: string } | null };
      const hasWebAuthn = (): boolean => Boolean(globalThis.PublicKeyCredential);
      const dialog = (): HTMLDialogElement | null => document.querySelector('#signin-dialog');
      const setStatus = (text: string): void => {
        const el = document.querySelector('#signin-status');
        if (el) el.textContent = text;
      };
      const showStep = (step: 'email' | 'code'): void => {
        document.querySelector('[data-step="email"]')?.toggleAttribute('hidden', step !== 'email');
        document.querySelector('[data-step="code"]')?.toggleAttribute('hidden', step !== 'code');
      };
      let pendingEmail = '';

      const signOut = async (): Promise<void> => {
        await fetch('/api/auth/logout', { method: 'POST' });
        location.href = '/';
      };

      // Discoverable-credential sign-in ceremony; true on success.
      const passkeyLogin = async (): Promise<boolean> => {
        try {
          const opt = (await (await fetch('/api/passkey/auth-options', { method: 'POST' })).json()) as {
            challengeId: string;
            options: import('@simplewebauthn/browser').PublicKeyCredentialRequestOptionsJSON;
          };
          const response = await startAuthentication({ optionsJSON: opt.options });
          const res = await fetch('/api/passkey/auth-verify', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ challengeId: opt.challengeId, response }),
          });
          return res.ok;
        } catch {
          return false;
        }
      };

      // Passkey registration (native browser prompt is the offer); true on success.
      const passkeyRegister = async (): Promise<boolean> => {
        try {
          const opt = (await (await fetch('/api/passkey/register-options', { method: 'POST' })).json()) as {
            challengeId: string;
            options: import('@simplewebauthn/browser').PublicKeyCredentialCreationOptionsJSON;
          };
          const response = await startRegistration({ optionsJSON: opt.options });
          const res = await fetch('/api/passkey/register-verify', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ challengeId: opt.challengeId, response }),
          });
          return res.ok;
        } catch {
          return false;
        }
      };

      // Open the dialog and immediately offer the passkey if one is usable.
      const openSignin = async (): Promise<void> => {
        showStep('email');
        setStatus('');
        dialog()?.showModal();
        if (!hasWebAuthn()) return;
        setStatus(auth.lookingPasskey);
        if (await passkeyLogin()) {
          location.reload();
          return;
        }
        setStatus('');
        document.querySelector<HTMLInputElement>('#signin-form input[name=email]')?.focus();
      };

      const renderAccount = (user: Me['user']): void => {
        document.querySelectorAll('[data-account]').forEach((slot) => {
          if (user) {
            const admin =
              user.role === 'admin'
                ? `<a class="account-admin" href="/admin/">${auth.moderation}</a>` +
                  `<a class="account-admin" href="/admin/users/">${auth.users}</a>`
                : '';
            slot.innerHTML =
              `<a class="account-submit" href="/submit">+ ${auth.addEvent}</a>` +
              admin +
              `<a class="account-handle" href="/settings">@${user.handle}</a>` +
              `<button type="button" class="account-signout" data-signout>${auth.signOut}</button>`;
            slot.querySelector('[data-signout]')?.addEventListener('click', signOut);
          } else {
            slot.innerHTML = `<button type="button" class="account-signin" data-signin>${auth.signIn}</button>`;
            slot.querySelector('[data-signin]')?.addEventListener('click', () => void openSignin());
          }
        });
      };

      const refreshAccount = async (): Promise<void> => {
        try {
          renderAccount(((await (await fetch('/api/auth/me')).json()) as Me).user);
        } catch {
          renderAccount(null);
        }
      };

      const bind = (sel: string, event: string, handler: (el: Element) => void): void => {
        const el = document.querySelector(sel);
        if (el && (el as HTMLElement).dataset['bound'] !== 'true') {
          (el as HTMLElement).dataset['bound'] = 'true';
          el.addEventListener(event, () => handler(el));
        }
      };

      const bindSignin = (): void => {
        const form = document.querySelector<HTMLFormElement>('#signin-form');
        if (form && form.dataset['emailBound'] !== 'true') {
          form.dataset['emailBound'] = 'true';
          form.addEventListener('submit', async (e) => {
            e.preventDefault();
            pendingEmail = String(new FormData(form).get('email') ?? '');
            setStatus(auth.sending);
            const res = await fetch('/api/auth/request', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ email: pendingEmail }),
            });
            if (!res.ok) return setStatus(auth.invalidEmail);
            const target = document.querySelector('[data-code-email]');
            if (target) target.textContent = pendingEmail;
            showStep('code');
            setStatus('');
            document.querySelector<HTMLInputElement>('#code-form input[name=code]')?.focus();
          });
        }
        const codeForm = document.querySelector<HTMLFormElement>('#code-form');
        if (codeForm && codeForm.dataset['bound'] !== 'true') {
          codeForm.dataset['bound'] = 'true';
          codeForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const code = String(new FormData(codeForm).get('code') ?? '').trim();
            setStatus(auth.verifying);
            const res = await fetch('/api/auth/verify-code', {
              method: 'POST',
              headers: { 'content-type': 'application/json' },
              body: JSON.stringify({ email: pendingEmail, code }),
            });
            const data = (await res.json().catch(() => ({}))) as { ok?: boolean; isNew?: boolean };
            if (res.ok && data.ok) location.href = data.isNew ? '/?setup=passkey' : '/';
            else setStatus(auth.badCode);
          });
        }
        bind('[data-code-back]', 'click', () => {
          showStep('email');
          setStatus('');
        });
        const passkeyBtn = document.querySelector<HTMLButtonElement>('#passkey-signin');
        if (passkeyBtn && hasWebAuthn() && passkeyBtn.dataset['bound'] !== 'true') {
          passkeyBtn.dataset['bound'] = 'true';
          document.querySelector('[data-passkey-alt]')?.removeAttribute('hidden');
          passkeyBtn.addEventListener('click', async () => {
            setStatus(auth.waitingPasskey);
            if (await passkeyLogin()) location.reload();
            else setStatus(auth.passkeyFailed);
          });
        }
      };

      const initAuthUi = (): void => {
        bindSignin();
        void refreshAccount();
        const params = new URLSearchParams(location.search);
        if (params.has('signin')) void openSignin();
        // Offer a passkey right after first registration (the native prompt).
        if (params.has('setup') && hasWebAuthn()) {
          void passkeyRegister().finally(() => history.replaceState(null, '', location.pathname));
        }
      };
      initAuthUi();
      document.addEventListener('astro:after-swap', initAuthUi);
    </script>
  </body>
</html>
