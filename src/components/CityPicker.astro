---
import { cachedEvents } from '../data/cached-events.ts';
import { EVENTS_URL } from '../data/events-url.ts';
import { citiesOf } from '../lib/city/cities-of.ts';
import { cityName } from '../lib/city/city-name.ts';
import { cityUrl } from '../lib/city/city-url.ts';
import type { Locale } from '../lib/i18n/locales.ts';

type Props = Readonly<{ lang: Locale; city: string; page?: string }>;
const { lang, city, page = '' } = Astro.props;

// Fifty-odd cities is too many to scroll: you type. The list is a plain <ul> of
// links, so it works before the script runs and the keyboard reaches it.
// Switching city keeps you on the page you are on — the calendar of Milan, not
// the feed of Milan.
const payload = await cachedEvents(EVENTS_URL);
const cities = citiesOf(payload.events);
---

<div class="city-picker" data-city-picker>
  <button type="button" class="city-current" data-city-toggle aria-expanded="false">
    <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M12 21s7-6.2 7-11a7 7 0 1 0-14 0c0 4.8 7 11 7 11Z"></path>
      <circle cx="12" cy="10" r="2.5"></circle>
    </svg>
    <span>{cityName(city)}</span>
    <span aria-hidden="true">▾</span>
  </button>

  <div class="city-pop" data-city-pop hidden>
    <label>
      <span class="visually-hidden">Search city</span>
      <input type="search" data-city-search placeholder="Type a city…" autocomplete="off" />
    </label>
    <ul data-city-list>
      {cities.map(({ slug, name, count }) => (
        <li data-name={name.toLowerCase()}>
          <a href={cityUrl(lang, slug, page)} aria-current={slug === city ? 'true' : undefined}>
            <span>{name}</span><small>{count}</small>
          </a>
        </li>
      ))}
    </ul>
    <p class="city-none" data-city-none hidden>No city matches.</p>
  </div>
</div>

<script>
  import { initCityPicker } from './city/init-city-picker.ts';
  initCityPicker();
</script>

<style>
  .city-picker { position: relative; }
  .city-current {
    display: inline-flex; align-items: center; gap: 0.35rem;
    border: 1px solid var(--line); background: var(--surface); color: var(--ink);
    padding: 0.35rem 0.6rem; border-radius: var(--radius-sm);
    font: inherit; font-size: 0.9rem; cursor: pointer;
  }
  .city-current:hover { border-color: var(--accent); }
  .city-pop {
    position: absolute; top: calc(100% + 0.4rem); right: 0; z-index: 60;
    width: 15rem; max-height: 22rem; display: flex; flex-direction: column;
    background: var(--surface); border: 1px solid var(--line);
    border-radius: var(--radius-sm); box-shadow: 0 12px 32px rgb(0 0 0 / 0.25);
    padding: 0.5rem;
  }
  .city-pop input {
    width: 100%; box-sizing: border-box; font: inherit; font-size: 0.9rem;
    padding: 0.4rem 0.55rem; border: 1px solid var(--line);
    border-radius: var(--radius-sm); background: var(--bg); color: var(--ink);
  }
  .city-pop ul { list-style: none; margin: 0.4rem 0 0; padding: 0; overflow-y: auto; }
  .city-pop a {
    display: flex; justify-content: space-between; gap: 0.5rem;
    padding: 0.35rem 0.5rem; border-radius: var(--radius-sm);
    text-decoration: none; color: var(--ink); font-size: 0.9rem;
  }
  .city-pop a:hover, .city-pop a:focus-visible { background: rgb(128 128 128 / 0.14); }
  .city-pop a[aria-current] { font-weight: 700; color: var(--accent); }
  .city-pop small { color: var(--ink-2); font-variant-numeric: tabular-nums; }
  .city-none { margin: 0.5rem; color: var(--ink-2); font-size: 0.85rem; }
</style>
