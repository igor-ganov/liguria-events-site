---
import { ClientRouter } from 'astro:transitions';
import { cachedEvents } from '../data/cached-events.ts';
import { EVENTS_URL } from '../data/events-url.ts';
import MobileMenu from '../components/MobileMenu.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { uiOf } from '../lib/i18n/ui-of.ts';
import { localizedUrl } from '../lib/i18n/localized-url.ts';
import { LOCALES } from '../lib/i18n/locales.ts';
import type { Locale } from '../lib/i18n/locales.ts';
import '../styles/global.css';

type Props = Readonly<{ lang: Locale; title: string; description?: string; path?: string }>;
const { lang, title, description = "What's on in Genoa — auto-collected events", path = '' } =
  Astro.props;

// Build-time boundary (AC-1.1): a failed fetch fails `astro build`.
const payload = await cachedEvents(EVENTS_URL);
const ui = await uiOf(lang);
const uiData = JSON.stringify({ lang, ui });
const alternates = LOCALES.map((loc) => ({
  loc,
  href: new URL(localizedUrl(loc, path), Astro.site).toString(),
}));
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="hsl(174 70% 30%)" />
    <title>{title} · Liguria Events</title>
    {alternates.map(({ loc, href }) => <link rel="alternate" hreflang={loc} href={href} />)}
    <ClientRouter />
    <script is:inline>
      // No-flash theme init (blog mechanics): only our two values, else OS.
      (function () {
        var pick = function () {
          var stored = localStorage.getItem('theme');
          return stored === 'dark' || stored === 'light'
            ? stored
            : window.matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
        };
        document.documentElement.dataset['theme'] = pick();
        document.addEventListener('astro:before-swap', function (e) {
          e.newDocument.documentElement.dataset['theme'] = pick();
        });
      })();
    </script>
  </head>
  <body>
    <header class="site-head">
      <p class="site-title"><a href={localizedUrl(lang)}>🌊 Liguria Events</a></p>
      <nav aria-label="Site">
        <a href={localizedUrl(lang)}>{ui.nav.calendar}</a>
        <a href={localizedUrl(lang, 'feed/')}>{ui.nav.feed}</a>
        <a href="https://t.me/liguria_events_bot" rel="noopener">{ui.nav.bot}</a>
        <a
          href="https://liguria-events-bot.igor-ganov.workers.dev/calendar.ics"
          rel="noopener">{ui.nav.ical}</a
        >
        <LanguageSwitcher lang={lang} path={path} />
        <button class="theme-btn" aria-label="Toggle theme" data-theme-toggle>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2" stroke-linecap="round">
            <circle class="sun" cx="12" cy="12" r="5"></circle>
            <line class="sun" x1="12" y1="1" x2="12" y2="3"></line>
            <line class="sun" x1="12" y1="21" x2="12" y2="23"></line>
            <line class="sun" x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line class="sun" x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line class="sun" x1="1" y1="12" x2="3" y2="12"></line>
            <line class="sun" x1="21" y1="12" x2="23" y2="12"></line>
            <line class="sun" x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line class="sun" x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            <path class="moon" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
        </button>
      </nav>
    </header>
    <script is:inline type="application/json" id="events-data" set:html={JSON.stringify(payload.events)} />
    <script is:inline type="application/json" id="ui-data" set:html={uiData} />
    <main>
      <slot />
    </main>
    <MobileMenu lang={lang} path={path} />
    <footer class="site-foot">
      <p>
        {ui.footer} · data as of {payload.generatedAt.slice(0, 16)}Z ·
        <a href="https://github.com/igor-ganov/liguria-events-site" rel="noopener">source</a>
      </p>
    </footer>
    <script>
      // Theme toggle with circular reveal (blog mechanics); re-bound after SPA swap.
      const html = document.documentElement;
      const setTheme = (theme: string): void => {
        html.dataset['theme'] = theme;
        localStorage.setItem('theme', theme);
      };
      const toggle = (event: MouseEvent): void => {
        const next = html.dataset['theme'] === 'dark' ? 'light' : 'dark';
        if (!document.startViewTransition) {
          setTheme(next);
          return;
        }
        const { clientX: x, clientY: y } = event;
        const r = Math.hypot(Math.max(x, innerWidth - x), Math.max(y, innerHeight - y));
        html.style.setProperty('--x', `${x}px`);
        html.style.setProperty('--y', `${y}px`);
        html.style.setProperty('--r', `${r}px`);
        document.startViewTransition({ update: () => setTheme(next), types: ['theme'] });
      };
      const bind = (): void => {
        document.querySelectorAll<HTMLElement>('[data-theme-toggle]').forEach((btn) => {
          if (btn.dataset['themeBound'] === 'true') return;
          btn.dataset['themeBound'] = 'true';
          btn.addEventListener('click', toggle);
        });
      };
      bind();
      document.addEventListener('astro:after-swap', bind);
    </script>
  </body>
</html>
