---
import CalendarView from '../../../components/views/CalendarView.astro';
import { LOCALES } from '../../../lib/i18n/locales.ts';
import { isoToday } from '../../../lib/calendar/iso-today.ts';
import { monthKeyOf } from '../../../lib/calendar/month-key-of.ts';

export const getStaticPaths = () =>
  LOCALES.filter((lang) => lang !== 'en').map((lang) => ({ params: { lang }, props: { lang } }));

const { lang } = Astro.props;
---

<CalendarView lang={lang} monthKey={monthKeyOf(isoToday())} />
