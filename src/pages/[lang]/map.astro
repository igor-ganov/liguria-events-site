---
import MapView from '../../components/views/MapView.astro';
import { LOCALES } from '../../lib/i18n/locales.ts';

export const getStaticPaths = () =>
  LOCALES.filter((lang) => lang !== 'en').map((lang) => ({ params: { lang }, props: { lang } }));

const { lang } = Astro.props;
---

<MapView lang={lang} />
