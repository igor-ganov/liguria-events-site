{
  "extends": "astro/tsconfigs/strictest",
  "include": ["src/**/*"],
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "useDefineForClassFields": false,
    "experimentalDecorators": true
  }
}
