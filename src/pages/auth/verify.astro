---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import { consumeMagicToken } from '../../lib/auth/magic.ts';
import { findOrCreateUser, rootAdmins } from '../../lib/auth/users.ts';
import { signSession, SESSION_COOKIE } from '../../lib/auth/session.ts';

const env = Astro.locals.runtime.env;
const token = Astro.url.searchParams.get('t') ?? '';
const email = await consumeMagicToken(env.SESSION, token);

if (email) {
  const nowMs = Date.now();
  const { user, isNew } = await findOrCreateUser(env.DB, email, new Date(nowMs).toISOString(), rootAdmins(env));
  const session = await signSession(env.SESSION_SECRET, user.id, nowMs);
  Astro.cookies.set(SESSION_COOKIE, session, {
    httpOnly: true,
    secure: true,
    sameSite: 'lax',
    path: '/',
    maxAge: 7 * 24 * 3600,
  });
  // Land on the home page; first-time users get offered a passkey.
  if (isNew) return Astro.redirect('/?setup=passkey');
  return Astro.redirect('/');
}
---

<Layout lang="en" title="Sign-in link" path="auth/verify/">
  <main class="auth-card">
    <h1>Link expired or already used</h1>
    <p>Sign-in links work only once and for five minutes. Please request a fresh one.</p>
    <a class="btn" href="/?signin=1">Back to sign in</a>
  </main>
</Layout>
