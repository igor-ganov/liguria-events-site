# Content-hashed + stable assets are immutable — cache hard so repeat visits
# (and the heavy map bundle) load from cache instead of re-downloading.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
/font/*
  Cache-Control: public, max-age=31536000, immutable
/sprite/*
  Cache-Control: public, max-age=2592000
# Landmark data refreshes weekly (stable filename, not hashed) — cache a day and
# serve stale while revalidating, so repeat opt-ins are instant but never stale.
/data/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
/favicon.svg
  Cache-Control: public, max-age=604800
