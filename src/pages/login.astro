---
import Layout from '../layouts/Layout.astro';
---

<Layout lang="en" title="Sign in" path="login/">
  <main class="auth-card">
    <h1>Sign in to Dove Go</h1>
    <p>Enter your email and we'll send you a one-time sign-in link.</p>
    <form id="magic-form">
      <input type="email" name="email" required placeholder="you@example.com" autocomplete="email" />
      <button type="submit">Send me a link</button>
    </form>
    <p id="status" role="status" aria-live="polite"></p>
  </main>
</Layout>

<script>
  const form = document.getElementById('magic-form') as HTMLFormElement;
  const status = document.getElementById('status') as HTMLElement;
  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    const email = new FormData(form).get('email');
    status.textContent = 'Sending…';
    const res = await fetch('/api/auth/request', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ email }),
    });
    status.textContent = res.ok
      ? '✓ Check your inbox for the sign-in link (it expires in 5 minutes).'
      : 'Something went wrong — please try again.';
  });
</script>
