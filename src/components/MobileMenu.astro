---
// Flying menu — draggable FAB ported from the blog's MobileMenu: a 56px round
// button fixed in one of four corners, dragged to snap to the nearest one
// (persisted in localStorage), opening a popup nav anchored to that corner.
import LanguageSwitcher from './LanguageSwitcher.astro';
import ThemeToggle from './ThemeToggle.astro';
import { uiOf } from '../lib/i18n/ui-of.ts';
import { localizedUrl } from '../lib/i18n/localized-url.ts';
import type { Locale } from '../lib/i18n/locales.ts';

type Props = Readonly<{ lang: Locale; path: string }>;
const { lang, path } = Astro.props;
const ui = await uiOf(lang);
const links = [
  { href: localizedUrl(lang), label: `🗓 ${ui.nav.calendar}` },
  { href: localizedUrl(lang, 'feed/'), label: `📋 ${ui.nav.feed}` },
  { href: localizedUrl(lang, 'map/'), label: `🗺 ${ui.nav.map}` },
  { href: 'https://t.me/liguria_events_bot', label: `🤖 ${ui.nav.bot}` },
  { href: 'https://liguria-events-bot.igor-ganov.workers.dev/calendar.ics', label: `📆 ${ui.nav.ical}` },
];
---

<div class="fab-menu" data-fab-wrapper data-corner="bottom-right">
  <script is:inline>
    (() => {
      try {
        const v = localStorage.getItem('fab-corner');
        if (['top-left', 'top-right', 'bottom-left', 'bottom-right'].includes(v)) {
          document.currentScript.parentElement.dataset.corner = v;
        }
      } catch {
        /* localStorage may be blocked; keep the default corner. */
      }
    })();
  </script>

  <button
    type="button"
    class="mobile-fab"
    data-fab-toggle
    aria-label="Menu"
    aria-expanded="false"
    aria-controls="fab-popup"
  >
    <span class="fab-line fab-line-1"></span>
    <span class="fab-line fab-line-2"></span>
    <span class="fab-line fab-line-3"></span>
  </button>

  <div class="fab-overlay" data-fab-overlay aria-hidden="true"></div>

  <nav id="fab-popup" class="fab-popup" data-fab-panel role="dialog" aria-modal="true" aria-label="Menu">
    <ul class="fab-links">
      {links.map(({ href, label }) => <li><a href={href}>{label}</a></li>)}
    </ul>
    <div class="fab-tools">
      <LanguageSwitcher lang={lang} path={path} />
      <ThemeToggle ui={ui} labelled />
    </div>
  </nav>
</div>

<script>
  type Corner = 'top-left' | 'top-right' | 'bottom-left' | 'bottom-right';
  const SIZE = 56, MARGIN = 16, GAP = 8, THRESHOLD = 10, KEY = 'fab-corner';

  const isCorner = (v: string | null): v is Corner =>
    v === 'top-left' || v === 'top-right' || v === 'bottom-left' || v === 'bottom-right';

  const fabXY = (c: Corner) => {
    const right = innerWidth - SIZE - MARGIN, bottom = innerHeight - SIZE - MARGIN;
    return {
      'top-left': { x: MARGIN, y: MARGIN }, 'top-right': { x: right, y: MARGIN },
      'bottom-left': { x: MARGIN, y: bottom }, 'bottom-right': { x: right, y: bottom },
    }[c];
  };

  const snap = (x: number, y: number): Corner =>
    `${y > innerHeight / 2 ? 'bottom' : 'top'}-${x > innerWidth / 2 ? 'right' : 'left'}`;

  const setup = () => {
    const wrap = document.querySelector<HTMLElement>('[data-fab-wrapper]');
    if (!wrap || wrap.dataset['fabInit'] === 'true') return;
    wrap.dataset['fabInit'] = 'true';
    const fab = wrap.querySelector<HTMLButtonElement>('[data-fab-toggle]');
    const overlay = wrap.querySelector<HTMLElement>('[data-fab-overlay]');
    const panel = wrap.querySelector<HTMLElement>('[data-fab-panel]');
    if (!fab || !overlay || !panel) return;

    const stored = localStorage.getItem(KEY);
    let corner: Corner = isCorner(stored) ? stored : 'bottom-right';
    let dragging = false, moved = false, sX = 0, sY = 0;

    const placeFab = (x: number, y: number, animate: boolean) => {
      fab.style.left = `${x}px`; fab.style.top = `${y}px`;
      fab.style.transition = animate ? 'all var(--speed)' : 'none';
    };
    const placePanel = (c: Corner) => {
      const right = c.endsWith('right'), bottom = c.startsWith('bottom');
      const off = `${MARGIN + SIZE + GAP}px`;
      panel.style.left = right ? 'auto' : `${MARGIN}px`;
      panel.style.right = right ? `${MARGIN}px` : 'auto';
      panel.style.top = bottom ? 'auto' : off;
      panel.style.bottom = bottom ? off : 'auto';
    };
    const settle = (c: Corner) => {
      corner = c; wrap.dataset['corner'] = c;
      const p = fabXY(c); placeFab(p.x, p.y, true); placePanel(c);
    };
    settle(corner);

    const open = () => { wrap.classList.add('open'); fab.setAttribute('aria-expanded', 'true'); panel.querySelector('a')?.focus(); };
    const close = () => { wrap.classList.remove('open'); fab.setAttribute('aria-expanded', 'false'); };

    fab.addEventListener('pointerdown', (e) => { dragging = true; moved = false; sX = e.clientX; sY = e.clientY; fab.setPointerCapture(e.pointerId); });
    fab.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      const dx = e.clientX - sX, dy = e.clientY - sY;
      if (Math.abs(dx) + Math.abs(dy) > THRESHOLD) moved = true;
      const b = fabXY(corner); placeFab(b.x + dx, b.y + dy, false);
    });
    fab.addEventListener('pointerup', (e) => {
      dragging = false; fab.releasePointerCapture(e.pointerId);
      if (moved) { const n = snap(e.clientX, e.clientY); localStorage.setItem(KEY, n); settle(n); return; }
      wrap.classList.contains('open') ? close() : open();
    });
    overlay.addEventListener('click', close);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
    panel.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
    addEventListener('resize', () => { const p = fabXY(corner); placeFab(p.x, p.y, false); });
  };

  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
