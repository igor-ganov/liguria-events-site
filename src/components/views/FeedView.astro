---
import Layout from '../../layouts/Layout.astro';
import { uiOf } from '../../lib/i18n/ui-of.ts';
import type { Locale } from '../../lib/i18n/locales.ts';

type Props = Readonly<{ lang: Locale }>;
const { lang } = Astro.props;
const ui = await uiOf(lang);
---

<Layout lang={lang} title={ui.nav.feed} path="" needsEvents>
  <h1 class="visually-hidden">{ui.nav.feed}</h1>
  <events-feed></events-feed>
</Layout>

<script>
  import '../../components/events-feed.ts';
</script>
