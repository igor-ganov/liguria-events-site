---
import Layout from '../../layouts/Layout.astro';
import { uiOf } from '../../lib/i18n/ui-of.ts';
import { CATEGORIES } from '../../lib/events/categories.ts';
import { iconSvg } from '../../lib/icons/icon-svg.ts';
import type { Locale } from '../../lib/i18n/locales.ts';

type Props = Readonly<{ lang: Locale }>;
const { lang } = Astro.props;
const ui = await uiOf(lang);
---

<Layout lang={lang} title={ui.nav.map} path="map/">
  <h1 class="visually-hidden">{ui.nav.map}</h1>
  <div class="map-filters">
    <div class="map-dates">
      <label>{ui.range.from} <input type="date" data-map-from /></label>
      <label>{ui.range.to} <input type="date" data-map-to /></label>
    </div>
    <div class="chips" role="group" aria-label="Filter by category">
      {
        CATEGORIES.map((category) => (
          <button class="chip" data-cat={category} data-map-cat={category} aria-pressed="false">
            <Fragment set:html={iconSvg(category, 14)} />
            {ui.cat[category]}
          </button>
        ))
      }
      <button class="chip chip--free" data-map-free aria-pressed="false">{ui.chips.free}</button>
      <button class="chip chip--gems" data-map-gems aria-pressed="false">{ui.chips.gems}</button>
      <button class="chip chip--clear" data-map-clear hidden>✕ {ui.chips.clear}</button>
    </div>
  </div>
  <div class="map-canvas" data-map-canvas></div>
</Layout>

<script>
  import maplibregl from 'maplibre-gl';
  import 'maplibre-gl/dist/maplibre-gl.css';
  import { Protocol } from 'pmtiles';
  import Supercluster from 'supercluster';
  import brightStyle from '../../lib/map/styles/bright.json';
  import darkStyle from '../../lib/map/styles/dark.json';
  import { inMapArea } from '../../lib/map/in-map-area.ts';
  import { mapEvents } from '../../lib/events/map-events.ts';
  import { categoryColor } from '../../lib/events/category-color.ts';
  import { primaryCategory } from '../../lib/events/primary-category.ts';
  import { titleOf } from '../../lib/events/title-of.ts';
  import { formatWhen } from '../../lib/events/format-when.ts';
  import { eventPath } from '../../lib/event-path.ts';
  import { iconSvg } from '../../lib/icons/icon-svg.ts';
  import { localizedUrl } from '../../lib/i18n/localized-url.ts';
  import { readEventsIsland } from '../../components/shared/read-events-island.ts';
  import { readUiIsland } from '../../components/shared/read-ui-island.ts';
  import { isoToday } from '../../lib/calendar/iso-today.ts';
  import type { Category } from '../../lib/events/categories.ts';
  import type { CompactEvent } from '../../lib/events/event-schema.ts';

  const ATTR = '© OpenMapTiles © OpenStreetMap contributors';
  const B = import.meta.env.BASE_URL.replace(/\/$/, '');
  const esc = (s: string): string =>
    s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/"/g, '&quot;');
  const plusDays = (iso: string, n: number): string => {
    const d = new Date(`${iso}T12:00:00Z`);
    d.setUTCDate(d.getUTCDate() + n);
    return d.toISOString().slice(0, 10);
  };

  // 'light' = OSM Bright (colourful, high contrast); 'dark' = retuned Dark Matter.
  const STYLES: Record<string, unknown> = { light: brightStyle, dark: darkStyle };

  const buildStyle = (key: string): maplibregl.StyleSpecification => {
    const dark = key === 'dark';
    const style = structuredClone(STYLES[key] ?? brightStyle) as maplibregl.StyleSpecification;
    style.sources = {
      openmaptiles: { type: 'vector', url: `pmtiles://${location.origin}${B}/tiles/liguria.pmtiles`, attribution: ATTR },
      // Free, no-key elevation tiles (Mapzen/AWS Open Data) for terrain relief.
      dem: {
        type: 'raster-dem',
        tiles: ['https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png'],
        encoding: 'terrarium',
        tileSize: 256,
        maxzoom: 14,
        attribution: '© Mapzen, USGS',
      },
    };
    style.glyphs = `${B}/font/{fontstack}/{range}.pbf`;
    style.sprite = `${B}/sprite/${dark ? 'dark' : 'bright'}/sprite`;
    // Light (OSM Bright) already ships self-hosted Noto Sans; Dark Matter
    // references fonts we don't host, so pin those to our single Regular face.
    if (dark) {
      for (const layer of style.layers) {
        const layout = (layer as { layout?: Record<string, unknown> }).layout;
        if (layout && layout['text-font']) layout['text-font'] = ['Noto Sans Regular'];
      }
    }
    // Relief (hillshade) under the roads/labels, for every basemap.
    const layers = style.layers as unknown as Array<Record<string, unknown>>;
    const hillshade = {
      id: 'hillshade',
      type: 'hillshade',
      source: 'dem',
      paint: {
        'hillshade-exaggeration': dark ? 0.45 : 0.3,
        'hillshade-shadow-color': dark ? '#000000' : '#6b6155',
        'hillshade-highlight-color': dark ? '#3a4654' : '#ffffff',
      },
    };
    const roadAt = layers.findIndex((l) => l['source-layer'] === 'transportation');
    layers.splice(roadAt >= 0 ? roadAt : 1, 0, hillshade);
    // Dark Matter's roads stay subtle even after retuning; add a brighter
    // major-road overlay so highways read clearly. (Light/OSM Bright is fine.)
    if (dark) {
      const roadHi = {
        id: 'road-highlight',
        type: 'line',
        source: 'openmaptiles',
        'source-layer': 'transportation',
        filter: ['in', ['get', 'class'], ['literal', ['motorway', 'trunk', 'primary', 'secondary', 'tertiary']]],
        layout: { 'line-cap': 'round', 'line-join': 'round' },
        paint: {
          'line-color': '#9aa6b5',
          'line-width': ['interpolate', ['linear'], ['zoom'], 7, 0.5, 11, 1.8, 15, 4.2],
          'line-opacity': 0.9,
        },
      };
      const symAt = layers.findIndex((l) => l['type'] === 'symbol');
      layers.splice(symAt >= 0 ? symAt : layers.length, 0, roadHi);
    }
    return style;
  };

  type EvProps = { ev: CompactEvent };

  const setup = (): void => {
    const canvas = document.querySelector<HTMLElement>('[data-map-canvas]');
    if (!canvas || canvas.dataset['ready'] === 'true') return;
    canvas.dataset['ready'] = 'true';

    maplibregl.addProtocol('pmtiles', new Protocol().tile);
    const events = readEventsIsland();
    const { lang } = readUiIsland();
    const href = (e: CompactEvent): string => localizedUrl(lang, eventPath(e.id));
    const thumb = (e: CompactEvent): string =>
      e.img ? `<img src="${e.img}" alt="" loading="lazy" referrerpolicy="no-referrer" />` : '';

    const today = isoToday();
    const sorted = [today, ...events.map((e) => e.e ?? e.s)].sort();
    const maxDate = sorted[sorted.length - 1] ?? today;
    const weekAhead = plusDays(today, 7);
    const defaultTo = weekAhead < maxDate ? weekAhead : maxDate; // upper filter defaults to +1 week
    const state = { from: today, to: defaultTo, selected: new Set<Category>(), freeOnly: false, gemsOnly: false };

    const readUrl = (): void => {
      const p = new URLSearchParams(location.search);
      (p.get('cat') ?? '').split(',').filter(Boolean).forEach((c) => state.selected.add(c as Category));
      state.freeOnly = p.get('free') === '1';
      state.gemsOnly = p.get('gems') === '1';
      state.from = p.get('from') ?? today;
      state.to = p.get('to') ?? defaultTo;
    };
    const writeUrl = (): void => {
      const p = new URLSearchParams();
      if (state.selected.size > 0) p.set('cat', [...state.selected].join(','));
      if (state.freeOnly) p.set('free', '1');
      if (state.gemsOnly) p.set('gems', '1');
      if (state.from !== today) p.set('from', state.from);
      if (state.to !== defaultTo) p.set('to', state.to);
      const qs = p.toString();
      history.replaceState(null, '', qs ? `${location.pathname}?${qs}` : location.pathname);
    };
    readUrl();

    // Basemap preference: 'auto' (follow the site theme) | 'light' | 'dark'.
    const MAP_STYLE_KEY = 'map-style';
    const isDark = (): boolean => document.documentElement.dataset['theme'] === 'dark';
    const pref = (): string => {
      const s = localStorage.getItem(MAP_STYLE_KEY) ?? 'auto';
      return s === 'light' || s === 'dark' ? s : 'auto';
    };
    const resolvedKey = (): string => (pref() === 'auto' ? (isDark() ? 'dark' : 'light') : pref());
    const map = new maplibregl.Map({
      container: canvas,
      style: buildStyle(resolvedKey()),
      center: [8.93, 44.41],
      zoom: 9,
      attributionControl: false,
    });
    map.addControl(new maplibregl.AttributionControl({ compact: true, customAttribution: ATTR }));
    map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-left');

    // "Where am I" — a plain button that is ALWAYS clickable and prompts for
    // geolocation on click. Gives feedback (loading / toast) because the map
    // only holds Liguria tiles: centring on a user elsewhere would look blank.
    const MSG: Record<string, Record<string, string>> = {
      outside: {
        en: 'You are outside the map area (Genoa / Liguria).',
        it: 'Sei fuori dall’area della mappa (Genova / Liguria).',
        ru: 'Вы вне области карты (Генуя / Лигурия).',
      },
      denied: {
        en: 'Location access is blocked — allow it in the browser.',
        it: 'Accesso alla posizione bloccato — consentilo nel browser.',
        ru: 'Доступ к геолокации запрещён — разрешите его в браузере.',
      },
      error: {
        en: 'Could not determine your location.',
        it: 'Impossibile determinare la posizione.',
        ru: 'Не удалось определить местоположение.',
      },
    };
    const say = (key: string): void => {
      const el = document.createElement('div');
      el.className = 'map-toast';
      el.textContent = MSG[key]?.[lang] ?? MSG[key]?.['en'] ?? '';
      canvas.appendChild(el);
      setTimeout(() => el.remove(), 4200);
    };
    let meMarker: maplibregl.Marker | undefined;
    const locateBtn = document.createElement('button');
    const requestPosition = (): void => {
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          locateBtn.classList.remove('map-locate-btn--busy');
          const at: [number, number] = [pos.coords.longitude, pos.coords.latitude];
          if (meMarker) {
            meMarker.setLngLat(at);
          } else {
            const dot = document.createElement('div');
            dot.className = 'map-me';
            meMarker = new maplibregl.Marker({ element: dot }).setLngLat(at).addTo(map);
          }
          if (inMapArea(at[0], at[1])) {
            map.easeTo({ center: at, zoom: Math.max(map.getZoom(), 14) });
          } else {
            say('outside');
          }
        },
        (err) => {
          locateBtn.classList.remove('map-locate-btn--busy');
          say(err.code === err.PERMISSION_DENIED ? 'denied' : 'error');
        },
        { enableHighAccuracy: true, timeout: 9000, maximumAge: 60000 },
      );
    };
    const locate = (): void => {
      if (!navigator.geolocation) {
        say('error');
        return;
      }
      locateBtn.classList.add('map-locate-btn--busy');
      // Call getCurrentPosition SYNCHRONOUSLY inside the click handler: browsers
      // only raise the permission prompt from within the user gesture, so any
      // await/.then() before this call would suppress it. A previously-denied
      // origin lands in the error callback (code 1) → the "blocked" message.
      requestPosition();
    };
    const locateControl = {
      onAdd(): HTMLElement {
        const wrap = document.createElement('div');
        wrap.className = 'maplibregl-ctrl maplibregl-ctrl-group';
        locateBtn.type = 'button';
        locateBtn.className = 'map-locate-btn';
        locateBtn.title = 'Find my location';
        locateBtn.setAttribute('aria-label', 'Find my location');
        locateBtn.innerHTML =
          '<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3.2"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/></svg>';
        locateBtn.addEventListener('click', locate);
        wrap.appendChild(locateBtn);
        return wrap;
      },
      onRemove(): void {
        /* nothing to tear down */
      },
    };
    map.addControl(locateControl, 'top-left');

    // Basemap switcher: Auto (follow the site theme) / Light / Dark. The DOM
    // photo markers are overlays and survive setStyle, so every option keeps
    // the events on the map. Choice persists; Auto tracks live theme changes.
    const STYLE_LABELS: Record<string, Record<string, string>> = {
      auto: { en: 'Auto', it: 'Auto', ru: 'Авто' },
      light: { en: 'Light', it: 'Chiara', ru: 'Светлая' },
      dark: { en: 'Dark', it: 'Scura', ru: 'Тёмная' },
    };
    let loadedKey = resolvedKey();
    const applyResolved = (): void => {
      const key = resolvedKey();
      if (key === loadedKey) return;
      loadedKey = key;
      map.setStyle(buildStyle(key));
    };
    const styleSelect = document.createElement('select');
    const styleControl = {
      onAdd(): HTMLElement {
        const wrap = document.createElement('div');
        wrap.className = 'maplibregl-ctrl maplibregl-ctrl-group map-style-ctrl';
        styleSelect.className = 'map-style-select';
        styleSelect.setAttribute('aria-label', 'Basemap style');
        const label = (k: string): string => STYLE_LABELS[k]?.[lang] ?? STYLE_LABELS[k]?.['en'] ?? k;
        for (const key of ['auto', 'light', 'dark']) {
          const opt = document.createElement('option');
          opt.value = key;
          opt.textContent = label(key);
          styleSelect.appendChild(opt);
        }
        styleSelect.value = pref();
        styleSelect.addEventListener('change', () => {
          localStorage.setItem(MAP_STYLE_KEY, styleSelect.value);
          applyResolved();
        });
        wrap.appendChild(styleSelect);
        return wrap;
      },
      onRemove(): void {
        /* nothing to tear down */
      },
    };
    map.addControl(styleControl, 'top-right');
    // While on Auto, follow the site theme live (data-theme is rewritten by the
    // theme script, including OS changes under the 'system' preference).
    new MutationObserver(() => {
      if (pref() === 'auto') applyResolved();
    }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
    window
      .matchMedia('(prefers-color-scheme: dark)')
      .addEventListener('change', () => {
        if (pref() === 'auto') applyResolved();
      });

    // ── popups ────────────────────────────────────────────────────────────────
    const openEvent = (e: CompactEvent, at: [number, number]): void => {
      new maplibregl.Popup({ closeButton: false, maxWidth: '260px', anchor: 'bottom', offset: 26 })
        .setLngLat(at)
        .setHTML(
          `<a class="map-pop" href="${href(e)}"><span class="map-pop-thumb">${thumb(e)}</span>` +
            `<span class="map-pop-title">${esc(titleOf(lang)(e))}</span>` +
            `<span class="map-pop-when">${esc(formatWhen(e))}</span></a>`,
        )
        .addTo(map);
    };
    const openCluster = (leaves: readonly CompactEvent[], at: [number, number]): void => {
      const rows = leaves
        .map(
          (e) =>
            `<a class="map-clus-row" href="${href(e)}"><span class="map-clus-thumb">${thumb(e)}</span>` +
            `<span class="map-clus-text"><span class="map-clus-title">${esc(titleOf(lang)(e))}</span>` +
            `<span class="map-pop-when">${esc(formatWhen(e))}</span></span></a>`,
        )
        .join('');
      new maplibregl.Popup({ closeButton: true, maxWidth: '300px', anchor: 'bottom', offset: 26, className: 'map-clus-popup' })
        .setLngLat(at)
        .setHTML(`<div class="map-clus-card"><div class="map-clus-head">${leaves.length}</div><div class="map-clus-list">${rows}</div></div>`)
        .addTo(map);
    };

    // ── markers (square photo) + cluster plaques ────────────────────────────────
    const eventMarkerEl = (e: CompactEvent): HTMLElement => {
      const el = document.createElement('div');
      el.className = 'ev-marker';
      el.style.setProperty('--c', categoryColor(primaryCategory(e.c)));
      const face = document.createElement('div');
      face.className = 'ev-marker-face';
      if (e.img) {
        const img = document.createElement('img');
        img.src = e.img;
        img.loading = 'lazy';
        img.referrerPolicy = 'no-referrer';
        img.alt = '';
        face.appendChild(img);
      } else {
        face.classList.add('ev-marker-face--icon');
        face.innerHTML = iconSvg(primaryCategory(e.c), 22);
      }
      el.appendChild(face);
      return el;
    };
    const clusterMarkerEl = (count: number): HTMLElement => {
      const el = document.createElement('div');
      el.className = 'ev-marker ev-cluster';
      el.innerHTML = `<div class="ev-cluster-face"><span>${count}</span></div>`;
      return el;
    };

    let index: Supercluster<EvProps> | undefined;
    const rebuildIndex = (): void => {
      const shown = mapEvents(state.from, state.to, [...state.selected], state.freeOnly, state.gemsOnly)(events);
      index = new Supercluster<EvProps>({ radius: 60, maxZoom: 15 });
      index.load(
        shown
          .filter((e) => e.g !== undefined)
          .map((e) => ({
            type: 'Feature',
            properties: { ev: e },
            geometry: { type: 'Point', coordinates: [e.g![1], e.g![0]] },
          })),
      );
    };

    const markers: maplibregl.Marker[] = [];
    const render = (): void => {
      if (!index) return;
      markers.forEach((m) => m.remove());
      markers.length = 0;
      const b = map.getBounds();
      const clusters = index.getClusters(
        [b.getWest(), b.getSouth(), b.getEast(), b.getNorth()],
        Math.round(map.getZoom()),
      );
      clusters.forEach((c) => {
        const at = c.geometry.coordinates as [number, number];
        const props = c.properties as { cluster?: boolean; cluster_id?: number; point_count?: number } & EvProps;
        if (props.cluster) {
          const el = clusterMarkerEl(props.point_count ?? 0);
          el.addEventListener('click', (ev) => {
            ev.stopPropagation();
            const leaves = (index?.getLeaves(props.cluster_id ?? 0, Infinity) ?? []).map((l) => (l.properties as EvProps).ev);
            openCluster(leaves, at);
          });
          markers.push(new maplibregl.Marker({ element: el, anchor: 'bottom' }).setLngLat(at).addTo(map));
        } else {
          const e = props.ev;
          const el = eventMarkerEl(e);
          el.addEventListener('click', (ev) => {
            ev.stopPropagation();
            openEvent(e, at);
          });
          markers.push(new maplibregl.Marker({ element: el, anchor: 'bottom' }).setLngLat(at).addTo(map));
        }
      });
    };

    let fitted = false;
    const fitAll = (): void => {
      const located = mapEvents(state.from, state.to, [...state.selected], state.freeOnly, state.gemsOnly)(events).filter(
        (e) => e.g !== undefined,
      );
      if (fitted || located.length === 0) return;
      const bounds = new maplibregl.LngLatBounds();
      located.forEach((e) => bounds.extend([e.g![1], e.g![0]]));
      map.fitBounds(bounds, { padding: 60, maxZoom: 13, duration: 0 });
      fitted = true;
    };

    map.on('load', () => {
      rebuildIndex();
      fitAll();
      render();
    });
    map.on('moveend', render);

    // ── controls ────────────────────────────────────────────────────────────────
    const clearEl = document.querySelector<HTMLElement>('[data-map-clear]');
    const freeEl = document.querySelector<HTMLButtonElement>('[data-map-free]');
    const gemsEl = document.querySelector<HTMLButtonElement>('[data-map-gems]');
    const catBtns = [...document.querySelectorAll<HTMLButtonElement>('[data-map-cat]')];
    const fromEl = document.querySelector<HTMLInputElement>('[data-map-from]');
    const toEl = document.querySelector<HTMLInputElement>('[data-map-to]');
    const anyFilter = (): boolean => state.selected.size > 0 || state.freeOnly || state.gemsOnly;

    const syncControls = (): void => {
      catBtns.forEach((b) => b.setAttribute('aria-pressed', String(state.selected.has(b.dataset['mapCat'] as Category))));
      freeEl?.setAttribute('aria-pressed', String(state.freeOnly));
      gemsEl?.setAttribute('aria-pressed', String(state.gemsOnly));
      if (fromEl) Object.assign(fromEl, { value: state.from, min: today, max: maxDate });
      if (toEl) Object.assign(toEl, { value: state.to, min: today, max: maxDate });
      if (clearEl) clearEl.hidden = !anyFilter();
    };
    const refresh = (): void => {
      writeUrl();
      syncControls();
      rebuildIndex();
      render();
    };

    catBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const cat = btn.dataset['mapCat'] as Category;
        state.selected.has(cat) ? state.selected.delete(cat) : state.selected.add(cat);
        refresh();
      });
    });
    freeEl?.addEventListener('click', () => {
      state.freeOnly = !state.freeOnly;
      refresh();
    });
    gemsEl?.addEventListener('click', () => {
      state.gemsOnly = !state.gemsOnly;
      refresh();
    });
    fromEl?.addEventListener('change', () => {
      state.from = fromEl.value;
      refresh();
    });
    toEl?.addEventListener('change', () => {
      state.to = toEl.value;
      refresh();
    });
    clearEl?.addEventListener('click', () => {
      state.selected.clear();
      state.freeOnly = false;
      state.gemsOnly = false;
      refresh();
    });

    syncControls();
  };

  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
