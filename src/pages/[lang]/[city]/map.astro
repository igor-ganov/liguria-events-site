---
import MapView from '../../../components/views/MapView.astro';
import { cachedEvents } from '../../../data/cached-events.ts';
import { EVENTS_URL } from '../../../data/events-url.ts';
import { citiesOf } from '../../../lib/city/cities-of.ts';
import { LOCALES } from '../../../lib/i18n/locales.ts';

export const getStaticPaths = async () => {
  const payload = await cachedEvents(EVENTS_URL);
  const cities = citiesOf(payload.events);
  return LOCALES.filter((lang) => lang !== 'en').flatMap((lang) =>
    cities.map(({ slug }) => ({ params: { lang, city: slug }, props: { lang, city: slug } })),
  );
};

const { lang, city } = Astro.props;
---

<MapView lang={lang} city={city} />
