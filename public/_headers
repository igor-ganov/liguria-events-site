# Content-hashed + stable assets are immutable — cache hard so repeat visits
# (and the heavy map bundle) load from cache instead of re-downloading.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable
/font/*
  Cache-Control: public, max-age=31536000, immutable
/sprite/*
  Cache-Control: public, max-age=2592000
/favicon.svg
  Cache-Control: public, max-age=604800
