{
  "name": "liguria-events-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Static calendar & feed UI for Genoa events — Astro + Lit on GitHub Pages",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "build:dev": "cross-env SITE_URL=https://dev.dovego.it PUBLIC_FIXED_TODAY=2026-07-06 PUBLIC_PMTILES_URL=https://dovego.it/tiles/liguria.pmtiles astro build",
    "preview": "astro preview",
    "test": "bun test",
    "lint": "eslint src",
    "typecheck": "astro check && tsc --noEmit -p tsconfig.test.json",
    "check": "bun run lint && bun run typecheck && bun test",
    "deploy:dev": "wrangler deploy --env dev",
    "deploy": "wrangler deploy",
    "d1:migrate:dev": "wrangler d1 migrations apply dovego-dev --env dev --remote",
    "d1:migrate": "wrangler d1 migrations apply dovego --remote"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "astro": "^5.17.1",
    "effect": "^3.19.4",
    "lit": "^3.3.2",
    "maplibre-gl": "^5.24.0",
    "pmtiles": "^4.4.1",
    "supercluster": "^8.0.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@cloudflare/workers-types": "^5.20260705.1",
    "@types/node": "^24.0.0",
    "@types/supercluster": "^7.1.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "wrangler": "^4.107.0"
  }
}
